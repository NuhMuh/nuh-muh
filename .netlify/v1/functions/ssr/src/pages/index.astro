---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import Masthead from '../components/Masthead.astro';
import WorkCard from '../components/WorkCard.astro';
import SidePanel from '../components/SidePanel.astro';
import PostcardSignup from '../components/PostcardSignup.astro';
import JoinScroll from '../components/JoinScroll.astro';
import { createClient } from '@supabase/supabase-js';

const supabase = createClient(
  process.env.SUPABASE_URL,
  process.env.SUPABASE_SECRET_KEY
);

// 주제 카드 + 글 읽기
const { data: works } = await supabase
  .from('works')
  .select('id, week, category, title, slug, hover_images')
  .order('week', { ascending: false });

const { data: articles } = await supabase
  .from('articles')
  .select('id, title, work_id, created_at')
  .eq('status', 'published');

const allWorks = works || [];
const allArticles = articles || [];

// 카테고리별 자리·색 (임의 지정 — 3단계에서 조정)
const CATEGORY_INFO = {
  '영상 너머': { spot: 'ga',  color: 'rust'  },
  '소설 너머': { spot: 'na',  color: 'deep'  },
  '인물 너머': { spot: 'da',  color: 'cold'  },
  '소식 너머': { spot: 'ra',  color: 'mossy' },
};

// 주제 카드 하나 → WorkCard가 먹는 형태로 변환
function toCard(w) {
  const info = CATEGORY_INFO[w.category] || { spot: 'da', color: 'warm' };
  const mine = allArticles
    .filter(a => a.work_id === w.id)
    .sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());
  return {
    id: w.slug,
    title: w.title,
    color: info.color,
    spot: info.spot,
    category: w.category,
    hoverImages: w.hover_images || [],
    articleTitles: mine.map(a => a.title),
    // WorkCard가 기대하지만 새 구조에서 안 쓰는 것들 — 빈 값
    number: '', tag: '', status: '', articleCount: mine.length,
  };
}

// 주차별로 묶기 (최신 주차 먼저)
const weekNums = [...new Set(allWorks.map(w => w.week))].sort((a, b) => b - a);
const sets = weekNums.map(week => {
  const cards = {};
  for (const w of allWorks.filter(x => x.week === week)) {
    cards[CATEGORY_INFO[w.category]?.spot || 'da'] = toCard(w);
  }
  return { week, cards };  // cards.ga / cards.na / cards.da / cards.ra (없으면 undefined = 빈 카드)
});
---

<BaseLayout title="Nuh-Muh">
  <div class="container">
    <Masthead />

    <div class="top-grid">
      <SidePanel />
    </div>

    <div class="week-sets">
      {sets.map((set, i) => (
        <div class={'week-set' + (i % 2 === 1 ? ' mirrored' : '')}>
          <div class="set-cards">
            {['ga','na','da','ra'].map((pos) => (
              <div class={'slot pos-' + pos}>
                {set.cards[pos]
                  ? <WorkCard work={set.cards[pos]} />
                  : <div class="empty-card" aria-hidden="true"></div>
                }
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>

  <PostcardSignup />
<JoinScroll />
</BaseLayout>

<style>
  .top-grid {
    display: flex;
    justify-content: flex-end;
    padding: 1rem 0 2rem;
  }

  .week-sets { display: flex; flex-direction: column; gap: 1.2rem; padding: 1rem 0 3rem; }

  .set-cards {
    display: grid;
    grid-template-columns: repeat(19, 1fr);
    grid-template-rows: 1fr 1fr;
    aspect-ratio: 9 / 5.0;
    gap: 1rem;
  }
  /* 정상 배치 — 가로 18칸: 가14 / 나4 / 다7 / 라7 */
  .pos-ga { grid-column: 1 / 13; grid-row: 1; }      /* 영상 12칸, 위 */
  .pos-na { grid-column: 13 / 20; grid-row: 1 / 3; } /* 소설 7칸, 두 행(책) */
  .pos-da { grid-column: 7 / 13; grid-row: 2; }      /* 인물 6칸 */
  .pos-ra { grid-column: 1 / 7; grid-row: 2; }       /* 소식 6칸 */

  /* 대칭 배치 (좌우 반전) */
  .mirrored .pos-ga { grid-column: 8 / 20; grid-row: 1; }
  .mirrored .pos-na { grid-column: 1 / 8; grid-row: 1 / 3; }
  .mirrored .pos-da { grid-column: 8 / 14; grid-row: 2; }
  .mirrored .pos-ra { grid-column: 14 / 20; grid-row: 2; }

  .slot { display: flex; min-width: 0; min-height: 0; }
  .slot :global(.card) { width: 100%; height: 100%; min-height: 0; }
  .slot .empty-card { width: 100%; height: 100%; min-height: 0; }

  .empty-card {
    width: 100%;
    border: 1.5px solid var(--rule-strong);
    border-radius: 18px;
    position: relative;
    overflow: hidden;
  }
  .empty-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      115deg,
      transparent 0%,
      transparent 18%,
      rgba(255, 252, 240, 0.38) 25%,
      transparent 32%,
      transparent 50%
    );
    background-size: 200% 100%;
    background-position: 0 0;
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }
  .empty-card:hover::after {
    opacity: 1;
    animation: empty-shimmer 3.6s linear infinite;
  }
  @keyframes empty-shimmer {
    from { background-position: 0 0; }
    to   { background-position: -200% 0; }
  }

  @media (max-width: 700px) {
    .set-cards { grid-template-columns: 1fr; grid-template-rows: none; }
    .pos-ga, .pos-na, .pos-da, .pos-ra,
    .mirrored .pos-ga, .mirrored .pos-na, .mirrored .pos-da, .mirrored .pos-ra {
      grid-column: 1; grid-row: auto;
    }
    .empty-card { min-height: 120px; }
  }
</style>
