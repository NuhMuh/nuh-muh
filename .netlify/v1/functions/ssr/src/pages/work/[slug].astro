---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { createClient } from '@supabase/supabase-js';

const supabase = createClient(
  process.env.SUPABASE_URL,
  process.env.SUPABASE_SECRET_KEY
);

const { slug } = Astro.params;

// 주제 카드 찾기
const { data: work } = await supabase
  .from('works')
  .select('id, week, category, title, slug')
  .eq('slug', slug)
  .maybeSingle();

if (!work) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

// 이 주제에 묶인 published 글들
const { data: articles } = await supabase
  .from('articles')
  .select('title, slug, subtitle, created_at')
  .eq('work_id', work.id)
  .eq('status', 'published')
  .order('created_at', { ascending: false });

const list = articles || [];
function fmt(iso) {
  if (!iso) return '';
  const d = new Date(iso);
  return d.getFullYear() + '. ' + (d.getMonth()+1) + '. ' + d.getDate() + '.';
}
---
<BaseLayout title={work.title + ' — Nuh-Muh'}>
  <div class="topic-wrap">
    <a href="/" class="topic-back">← 너머</a>
    <div class="topic-head">
      <span class="topic-cat">{work.category}</span>
      <h1 class="topic-title">{work.title}</h1>
    </div>
    {list.length === 0 ? (
      <p class="topic-empty">아직 글이 없습니다.</p>
    ) : (
      <ul class="topic-list">
        {list.map(a => (
          <li>
            <a href={'/' + a.slug}>
              <span class="a-date">{fmt(a.created_at)}</span>
              <span class="a-title">{a.title}</span>
              {a.subtitle && <span class="a-sub">{a.subtitle}</span>}
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</BaseLayout>

<style>
  /* 임시 페이지 — 디자인은 추후. 기능 확인용 최소 스타일 */
  .topic-wrap { max-width: 720px; margin: 0 auto; padding: 2rem 1.2rem 6rem; }
  .topic-back { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; letter-spacing: 0.15em; color: var(--ink-soft); text-decoration: none; display: inline-block; margin-bottom: 2.5rem; }
  .topic-back:hover { color: var(--mark); }
  .topic-head { border-bottom: 1px solid var(--rule-strong); padding-bottom: 1.5rem; margin-bottom: 2rem; }
  .topic-cat { font-family: 'JetBrains Mono', monospace; font-size: 0.66rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--mark); }
  .topic-title { font-family: 'Noto Serif KR', serif; font-weight: 500; font-size: 2.4rem; margin-top: 0.6rem; }
  .topic-empty { font-family: 'EB Garamond', serif; font-style: italic; color: var(--ink-faint); }
  .topic-list { list-style: none; }
  .topic-list li { border-bottom: 1px solid var(--rule); }
  .topic-list a { display: flex; flex-direction: column; gap: 0.3rem; padding: 1.3rem 0; text-decoration: none; color: inherit; transition: padding-left 0.3s; }
  .topic-list a:hover { padding-left: 0.5rem; }
  .topic-list a:hover .a-title { color: var(--mark); }
  .a-date { font-family: 'JetBrains Mono', monospace; font-size: 0.62rem; letter-spacing: 0.1em; color: var(--ink-faint); }
  .a-title { font-family: 'Noto Serif KR', serif; font-size: 1.25rem; color: var(--ink); transition: color 0.3s; }
  .a-sub { font-family: 'EB Garamond', serif; font-style: italic; font-size: 0.95rem; color: var(--ink-soft); }
</style>
