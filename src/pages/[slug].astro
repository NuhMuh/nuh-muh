---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import { createClient } from '@supabase/supabase-js';

const supabase = createClient(
  process.env.SUPABASE_URL,
  process.env.SUPABASE_SECRET_KEY
);

const { slug } = Astro.params;

const { data: article } = await supabase
  .from('articles')
  .select('*')
  .eq('slug', slug)
  .eq('status', 'published')
  .maybeSingle();

if (!article) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const dateStr = article.created_at ? new Date(article.created_at).toLocaleDateString('ko-KR') : '';
---
<BaseLayout title={article.title + " — Nuh-Muh"}>
  <article class="art-wrap">
    <a href="/" class="art-back">← 너머</a>

    <p class="art-category">{article.category}</p>
    <h1 class="art-title">{article.title}</h1>
    {article.subtitle && <p class="art-subtitle">{article.subtitle}</p>}

    <div class="art-meta">
      <span class="art-author">{article.author}</span>
      <span class="art-dot">·</span>
      <span class="art-date">{dateStr}</span>
    </div>

    {article.cover_image && (
      <img class="art-cover" src={article.cover_image} alt={article.cover_alt || ""} />
    )}

    <div class="art-body" set:html={article.body}></div>

    {article.tags && article.tags.length > 0 && (
      <div class="art-tags">
        {article.tags.map((t) => <span class="art-tag">{t}</span>)}
      </div>
    )}

    {article.work && (
      <p class="art-work">이 글은 「{article.work}」에 대한 글입니다.</p>
    )}
  </article>
</BaseLayout>

<style>
  .art-wrap { max-width: 680px; margin: 0 auto; padding: 3rem 1.2rem 6rem; }
  .art-back { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; letter-spacing: 0.15em; color: var(--ink-soft); text-decoration: none; display: inline-block; margin-bottom: 3rem; }
  .art-back:hover { color: var(--mark); }
  .art-category { font-family: 'Cormorant Unicase', serif; font-size: 0.9rem; letter-spacing: 0.1em; color: var(--mark); margin-bottom: 0.8rem; }
  .art-title { font-family: 'Noto Serif KR', serif; font-weight: 600; font-size: 2.3rem; line-height: 1.3; margin-bottom: 0.8rem; }
  .art-subtitle { font-family: 'EB Garamond', serif; font-style: italic; font-size: 1.25rem; color: var(--ink-soft); line-height: 1.5; margin-bottom: 1.4rem; }
  .art-meta { font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; letter-spacing: 0.08em; color: var(--ink-faint); margin-bottom: 2.6rem; }
  .art-dot { margin: 0 0.5rem; }
  .art-cover { width: 100%; border-radius: 6px; margin-bottom: 2.6rem; }
  .art-body { font-family: 'Noto Serif KR', serif; font-weight: 400; font-size: 1.08rem; line-height: 1.95; color: var(--ink); }
  .art-body :global(p) { margin-bottom: 1.5rem; }
  .art-body :global(h2) { font-size: 1.5rem; font-weight: 600; margin: 2.6rem 0 1rem; }
  .art-body :global(h3) { font-size: 1.25rem; font-weight: 600; margin: 2rem 0 0.8rem; }
  .art-body :global(img) { max-width: 100%; border-radius: 6px; margin: 1.6rem 0; }
  .art-body :global(img) { display: block; height: auto; }
  .art-body :global(img[data-size="xs"]) { max-width: 25%; }
  .art-body :global(img[data-size="sm"]) { max-width: 40%; }
  .art-body :global(img[data-size="md"]) { max-width: 60%; }
  .art-body :global(img[data-size="lg"]) { max-width: 80%; }
  .art-body :global(img[data-size="full"]) { max-width: 100%; }
  .art-body :global(img[data-align="left"]) { margin-right: auto; margin-left: 0; }
  .art-body :global(img[data-align="center"]) { margin-left: auto; margin-right: auto; }
  .art-body :global(img[data-align="right"]) { margin-left: auto; margin-right: 0; }
  .art-body :global(figure) { margin: 1.6rem 0; }
  .art-body :global(figure[data-size="xs"]) { max-width: 25%; }
  .art-body :global(figure[data-size="sm"]) { max-width: 40%; }
  .art-body :global(figure[data-size="md"]) { max-width: 60%; }
  .art-body :global(figure[data-size="lg"]) { max-width: 80%; }
  .art-body :global(figure[data-size="full"]) { max-width: 100%; }
  .art-body :global(figure[data-align="left"]) { margin-right: auto; margin-left: 0; }
  .art-body :global(figure[data-align="center"]) { margin-left: auto; margin-right: auto; }
  .art-body :global(figure[data-align="right"]) { margin-left: auto; margin-right: 0; }
  .art-body :global(figure img) { display: block; max-width: 100%; height: auto; margin: 0; }
  .art-body :global(figcaption) { font-size: 0.85rem; color: var(--ink-soft); margin-top: 0.5rem; line-height: 1.6; }
  .art-body :global(figure[data-align="left"] figcaption) { text-align: left; }
  .art-body :global(figure[data-align="center"] figcaption) { text-align: center; }
  .art-body :global(figure[data-align="right"] figcaption) { text-align: right; }
  .art-body :global(div[data-nm-group]) { margin: 1.6rem 0; }
  .art-body :global(div[data-nm-group][data-size="xs"]) { max-width: 40%; }
  .art-body :global(div[data-nm-group][data-size="sm"]) { max-width: 55%; }
  .art-body :global(div[data-nm-group][data-size="md"]) { max-width: 70%; }
  .art-body :global(div[data-nm-group][data-size="lg"]) { max-width: 85%; }
  .art-body :global(div[data-nm-group][data-size="full"]) { max-width: 100%; }
  .art-body :global(div[data-nm-group][data-align="left"]) { margin-right: auto; margin-left: 0; }
  .art-body :global(div[data-nm-group][data-align="center"]) { margin-left: auto; margin-right: auto; }
  .art-body :global(div[data-nm-group][data-align="right"]) { margin-left: auto; margin-right: 0; }
  .art-body :global(div[data-nm-group-row]) { display: flex; gap: 0.6rem; }
  .art-body :global(div[data-nm-group-row] img) { width: 50%; height: auto; object-fit: cover; display: block; margin: 0; border-radius: 6px; }
  .art-body :global(div[data-nm-group] figcaption) { display: flex; gap: 0.6rem; margin-top: 0.5rem; font-size: 0.85rem; color: var(--ink-soft); line-height: 1.6; }
  .art-body :global(div[data-nm-group] figcaption span) { width: 50%; text-align: center; }
  @media (max-width: 600px) {
    .art-body :global(div[data-nm-group]) { max-width: 100% !important; }
    .art-body :global(div[data-nm-group-row]) { flex-direction: column; }
    .art-body :global(div[data-nm-group-row] img) { width: 100%; }
  }
  .art-body :global(a) { color: var(--mark); text-underline-offset: 3px; }
  .art-body :global(blockquote) { border-left: 2px solid var(--mark); padding-left: 1.2rem; margin: 1.6rem 0; color: var(--ink-soft); font-style: italic; }
  .art-tags { margin-top: 3.5rem; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .art-tag { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: var(--ink-soft); border: 1px solid var(--rule); border-radius: 999px; padding: 0.25rem 0.7rem; }
  .art-work { font-family: 'EB Garamond', serif; font-style: italic; font-size: 0.95rem; color: var(--ink-faint); margin-top: 2rem; }
</style>
