---
import BaseLayout from '../layouts/BaseLayout.astro';
import Masthead from '../components/Masthead.astro';
import WorkCard from '../components/WorkCard.astro';
import SidePanel from '../components/SidePanel.astro';
import PostcardSignup from '../components/PostcardSignup.astro';
import JoinScroll from '../components/JoinScroll.astro';
import InterviewCard from '../components/InterviewCard.astro';
import CritiqueCard from '../components/CritiqueCard.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const allWorks = await getCollection('works');
const sorted = allWorks.sort((a, b) => a.data.order - b.data.order);

const spotlightEntry = sorted.find(w => w.data.isSpotlight);
const nonSpotlight = sorted.filter(w => !w.data.isSpotlight);
const inProgress = nonSpotlight.filter(w => !w.data.done);
const completed = nonSpotlight.filter(w => w.data.done);

const allArticles = await getCollection('articles');
const articleCountMap = new Map<string, number>();
for (const article of allArticles) {
  articleCountMap.set(article.data.work, (articleCountMap.get(article.data.work) || 0) + 1);
}

// 최신 글이 올라온 작품 = 스포트라이트
const articlesByDate = [...allArticles].sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const latestArticle = articlesByDate[0];
const spotlightWorkId = latestArticle ? latestArticle.data.work : (spotlightEntry ? spotlightEntry.id : null);

function toWork(entry: CollectionEntry<'works'>, excerpt?: string) {
  return {
    id: entry.id,
    number: entry.data.number,
    title: entry.data.title,
    tag: entry.data.tag,
    color: entry.data.color,
    status: entry.data.status,
    kicker: entry.data.kicker,
    coverImage: entry.data.coverImage,
    articleCount: articleCountMap.get(entry.id) || 0,
    excerpt,
    isComing: entry.data.isComing,
    slotSize: entry.data.slotSize,
    hoverImages: entry.data.hoverImages,
    articleTitles: allArticles.filter(a => a.data.work === entry.id).sort((a,b)=>new Date(b.data.date).getTime()-new Date(a.data.date).getTime()).map(a => a.data.title),
  };
}

// 슬롯 패턴: 5-4-3 / 3-5-4 / 4-3-5 반복
const SLOT_PATTERN = [5, 4, 3, 3, 5, 4, 4, 3, 5];

// 작품들을 슬롯에 채우는 함수
function fillSlots(works: CollectionEntry<'works'>[], slotCount: number) {
  // 크기별 작품 큐
  const queues: Record<number, CollectionEntry<'works'>[]> = { 3: [], 4: [], 5: [] };
  for (const w of works) {
    const s = w.data.slotSize;
    (queues[s] || queues[4]).push(w);
  }
  const slots: Array<{ size: number; work: CollectionEntry<'works'> | null }> = [];
  for (let i = 0; i < slotCount; i++) {
    const size = SLOT_PATTERN[i % SLOT_PATTERN.length];
    const work = queues[size] && queues[size].length ? queues[size].shift()! : null;
    slots.push({ size, work });
  }
  return slots;
}

const spotlightWorkEntry = sorted.find(w => w.id === spotlightWorkId);
const spotlight = spotlightWorkEntry ? toWork(spotlightWorkEntry) : null;
const progressSlots = fillSlots(inProgress, 12);
const completedSlots = fillSlots(completed, 18);
---

<BaseLayout title="Nuh-Muh">
  <div class="container">
    <Masthead />

    <div class="top-grid">
      {spotlight && <div class="spotlight-wrap"><WorkCard work={spotlight} isSpotlight={true} /></div>}
      <SidePanel />
    </div>

    <div class="works-masonry">
      {progressSlots.map((slot) => (
        slot.work
          ? <WorkCard work={toWork(slot.work)} />
          : <div class={'empty-slot slot-' + slot.size} aria-hidden="true"></div>
      ))}
    </div>


    <div class="middle-cards">
      <InterviewCard />
      <CritiqueCard />
    </div>

    <div class="works-masonry">
      {completedSlots.map((slot) => (
        slot.work
          ? <WorkCard work={toWork(slot.work)} />
          : <div class={'empty-slot slot-' + slot.size} aria-hidden="true"></div>
      ))}
    </div>
  </div>

  <PostcardSignup />
<JoinScroll />
</BaseLayout>

<style>
  .top-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 1.1rem;
    padding: 1rem 0 1.2rem;
    align-items: stretch;
  }
  .spotlight-wrap { grid-column: span 9; display: flex; }
  .spotlight-wrap :global(.card) { width: 100%; }
  .works-masonry {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 1.2rem;
    padding: 1.2rem 0;
    align-items: stretch;
  }
  .works-masonry :global(.card) { width: 100%; }
  .middle-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.2rem;
    padding: 1.5rem 0;
  }
  @media (max-width: 700px) { .middle-cards { grid-template-columns: 1fr; } }
  .empty-slot {
    border: 1.5px solid var(--ink-soft);
    border-radius: 18px;
    min-height: 280px;
  }
  .slot-3 { grid-column: span 3; }
  .slot-4 { grid-column: span 4; }
  .slot-5 { grid-column: span 5; }
  @media (max-width: 700px) {
    .top-grid { grid-template-columns: 1fr; }
    .works-masonry { grid-template-columns: 1fr; }
    .works-masonry :global(.card),
    .empty-slot { grid-column: span 1 !important; }
  }
</style>
