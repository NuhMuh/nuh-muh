---
import BaseLayout from '../layouts/BaseLayout.astro';
import Masthead from '../components/Masthead.astro';
import SpotlightCard from '../components/SpotlightCard.astro';
import WorkCard from '../components/WorkCard.astro';
import LatestAside from '../components/LatestAside.astro';
import PostcardSignup from '../components/PostcardSignup.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const allWorks = await getCollection('works');
const sorted = allWorks.sort((a, b) => a.data.order - b.data.order);

const spotlightEntry = sorted.find(w => w.data.isSpotlight);
const otherWorks = sorted.filter(w => !w.data.isSpotlight);

const allArticles = await getCollection('articles');
const articleCountMap = new Map<string, number>();
for (const article of allArticles) {
  articleCountMap.set(article.data.work, (articleCountMap.get(article.data.work) || 0) + 1);
}

const spotlightArticles = allArticles
  .filter(a => a.data.work === spotlightEntry?.id)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const spotlightLead = spotlightArticles.find(a => a.data.isLead) || spotlightArticles[0];

function toWork(entry: CollectionEntry<'works'>, excerpt?: string) {
  return {
    id: entry.id,
    number: entry.data.number,
    title: entry.data.title,
    tag: entry.data.tag,
    color: entry.data.color,
    status: entry.data.status,
    kicker: entry.data.kicker,
    coverImage: entry.data.coverImage,
    articleCount: articleCountMap.get(entry.id) || 0,
    excerpt,
    isComing: entry.data.isComing,
  };
}

const spotlight = spotlightEntry ? toWork(spotlightEntry, spotlightLead?.data.excerpt) : null;
const works = otherWorks.map(w => toWork(w));

const positions: Array<'m1' | 'm2' | 'm3' | 'm4' | 'm5'> = ['m1', 'm2', 'm3', 'm4', 'm5'];
const revealClasses = ['reveal-4', 'reveal-5', 'reveal-6', 'reveal-7', 'reveal-8'];
---

<BaseLayout title="Nuh-Muh">
  <div class="container">
    <Masthead />

    <div class="works-grid">
      {spotlight && <SpotlightCard work={spotlight} revealClass="reveal-2" />}
      <LatestAside />

      {works.slice(0, 5).map((work, i) => (
        <WorkCard work={work} position={positions[i]} revealClass={revealClasses[i]} />
      ))}
    </div>
  </div>

  <PostcardSignup />
</BaseLayout>

<style>
  .works-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 1.1rem;
    padding: 1rem 0 5rem;
  }
  @media (max-width: 900px) {
    .works-grid { grid-template-columns: 1fr; gap: 0.9rem; }
  }
</style>
