---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="발행소 — Nuh-Muh">
  <div class="desk-wrap" id="desk-wrap" style="opacity:0;">
    <a href="/" class="desk-back">← 나가기</a>
    <h1 class="desk-title">발행소</h1>
    <p class="desk-note" id="desk-note">불러오는 중...</p>

    <div class="desk-form" id="desk-form" style="display:none;">
      <div class="f-editbar">
        <label class="f-label">기존 글 수정 <span class="f-hint">발행된 글을 불러와 고칩니다</span></label>
        <div class="f-editrow">
          <select id="f-editpick" class="f-input"><option value="">— 새 글 쓰기 —</option></select>
          <button type="button" id="f-newbtn" class="f-newbtn">새 글</button>
        </div>
        <p class="f-editmode" id="f-editmode"></p>
      </div>

      <label class="f-label">제목</label>
      <input type="text" id="f-title" class="f-input" placeholder="글 제목" />

      <label class="f-label">부제 / 한 줄 소개</label>
      <input type="text" id="f-subtitle" class="f-input" placeholder="비워도 됩니다" />

      <label class="f-label">주제 카드</label>
      <div class="f-topic-modes">
        <label class="f-radio"><input type="radio" name="topic-mode" value="solo" checked /> 단독 글</label>
        <label class="f-radio"><input type="radio" name="topic-mode" value="existing" /> 기존 카드에 추가</label>
        <label class="f-radio"><input type="radio" name="topic-mode" value="new" /> 새 주제 카드</label>
      </div>

      <div class="f-topic-solo" id="topic-solo">
        <label class="f-label">분류 <span class="f-hint">단독 글의 카테고리</span></label>
        <select id="f-category" class="f-input">
          <option value="공지">공지</option>
        </select>
      </div>

      <div class="f-topic-existing" id="topic-existing" style="display:none;">
        <label class="f-label">주제 카드 선택</label>
        <select id="f-workid" class="f-input"><option value="">불러오는 중...</option></select>
      </div>

      <div class="f-topic-new" id="topic-new" style="display:none;">
        <div class="f-row">
          <div>
            <label class="f-label">넘기 번호 <span class="f-hint">몇 번째 넘기인가 (발행 회차, 누적)</span></label>
            <input type="number" id="f-nw-week" class="f-input" placeholder="1" min="1" />
          </div>
          <div>
            <label class="f-label">카테고리(자리)</label>
            <select id="f-nw-category" class="f-input">
              <option value="영상 너머">영상 너머 (가)</option>
              <option value="소설 너머">소설 너머 (나)</option>
              <option value="인물 너머">인물 너머 (다)</option>
              <option value="소식 너머">소식 너머 (라)</option>
            </select>
          </div>
        </div>
        <label class="f-label">주제 카드 제목</label>
        <input type="text" id="f-nw-title" class="f-input" placeholder="예: 위처 3" />
        <label class="f-label">주제 카드 주소(slug)</label>
        <input type="text" id="f-nw-slug" class="f-input" placeholder="제목에서 자동 생성됩니다" />
      </div>

      <label class="f-label">글 주소(slug)</label>
      <input type="text" id="f-slug" class="f-input" placeholder="제목에서 자동 생성됩니다" />

      <label class="f-label">태그 <span class="f-hint">쉼표로 구분</span></label>
      <input type="text" id="f-tags" class="f-input" placeholder="예: 서사, 분기, 선택 (비워도 됩니다)" />

      <label class="f-label">대표 이미지 주소</label>
      <input type="text" id="f-cover" class="f-input" placeholder="https://... (비워도 됩니다)" />

      <label class="f-label">대표 이미지 설명(alt)</label>
      <input type="text" id="f-coveralt" class="f-input" placeholder="이미지를 설명하는 짧은 글 (비워도 됩니다)" />

      <label class="f-label">본문 <span class="f-hint">글을 씁니다 — 소스보기로 HTML 직접 편집도 가능</span></label>

      <div class="ed-bar">
        <div class="ed-tools" id="ed-tools">
          <button type="button" data-cmd="bold" title="굵게"><b>B</b></button>
          <button type="button" data-cmd="italic" title="기울임"><i>I</i></button>
          <button type="button" data-cmd="link" title="링크">🔗</button>
          <span class="ed-sep"></span>
          <button type="button" data-cmd="h2" title="소제목">H2</button>
          <button type="button" data-cmd="h3" title="작은 소제목">H3</button>
          <button type="button" data-cmd="quote" title="인용">❝</button>
          <button type="button" data-cmd="bullet" title="글머리 목록">• 목록</button>
          <button type="button" data-cmd="ordered" title="번호 목록">1. 목록</button>
          <button type="button" data-cmd="image" title="사진 넣기">사진</button>
          <button type="button" data-cmd="imagegroup" title="사진 2장 나란히">2장 묶음</button>
          <span class="ed-sep"></span>
          <button type="button" data-cmd="size-xs" title="아주 작게" class="ed-imgsize">XS</button>
          <button type="button" data-cmd="size-sm" title="작게" class="ed-imgsize">S</button>
          <button type="button" data-cmd="size-md" title="중간" class="ed-imgsize">M</button>
          <button type="button" data-cmd="size-lg" title="크게" class="ed-imgsize">L</button>
          <button type="button" data-cmd="size-full" title="전폭" class="ed-imgsize">전폭</button>
          <span class="ed-sep"></span>
          <button type="button" data-cmd="align-left" title="왼쪽" class="ed-imgalign">⬅</button>
          <button type="button" data-cmd="align-center" title="가운데" class="ed-imgalign">■</button>
          <button type="button" data-cmd="align-right" title="오른쪽" class="ed-imgalign">➡</button>
          <span class="ed-sep"></span>
          <button type="button" data-cmd="caption" title="캡션(출처·설명)" class="ed-imgcaption">캡션</button>
          <button type="button" data-cmd="ungroup" title="2장 묶음 풀기" class="ed-imgungroup">묶음 풀기</button>
        </div>
        <button type="button" id="ed-source-toggle" class="ed-source-toggle">&lt;/&gt; 소스보기</button>
      </div>

      <div id="ed-editor" class="ed-editor"></div>

      <p class="f-warn" id="f-bodywarn" style="display:none;">⚠ 소스보기 모드입니다. 문단 태그의 <code>data-anchor</code> 속성은 지우지 마십시오. (담기 기능이 이 표식으로 위치를 기억합니다)</p>
      <textarea id="f-body" class="f-textarea" rows="16" style="display:none;" placeholder="&lt;p&gt;본문 HTML...&lt;/p&gt;"></textarea>

      <details class="f-details">
        <summary>검색·공유 설정 (SEO)</summary>
        <label class="f-label">메타 설명</label>
        <input type="text" id="f-metadesc" class="f-input" placeholder="검색결과에 뜨는 요약 (비우면 자동)" />
        <label class="f-label">OG 이미지 주소</label>
        <input type="text" id="f-ogimage" class="f-input" placeholder="링크 공유 시 썸네일 (비우면 대표이미지)" />
      </details>

      <div class="f-row">
        <div>
          <label class="f-label">발행 상태</label>
          <select id="f-status" class="f-input">
            <option value="draft">초안 (저장만)</option>
            <option value="published">게시 (공개)</option>
            <option value="hidden">숨김</option>
          </select>
        </div>
        <label class="f-check">
          <input type="checkbox" id="f-pinned" /> 고정 글
        </label>
      </div>

      <button type="button" id="f-save" class="f-save">저장</button>
      <p class="f-result" id="f-result"></p>
    </div>
  </div>

<style>
  .desk-wrap { max-width: 760px; margin: 0 auto; padding: 2rem 1.2rem 6rem; transition: opacity 0.4s ease; }
  .desk-back { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; letter-spacing: 0.15em; color: var(--ink-soft); text-decoration: none; display: inline-block; margin-bottom: 2rem; }
  .desk-back:hover { color: var(--mark); }
  .desk-title { font-family: 'Noto Serif KR', serif; font-weight: 500; font-size: 2.2rem; margin-bottom: 0.4rem; }
  .desk-note { font-family: 'EB Garamond', serif; font-style: italic; color: var(--ink-soft); margin-bottom: 2.4rem; }
  .desk-form { display: flex; flex-direction: column; }
  .f-editbar { border: 1px dashed var(--rule); border-radius: 4px; padding: 0.3rem 0.9rem 0.9rem; margin-bottom: 0.6rem; background: rgba(139,58,46,0.03); }
  .f-editrow { display: flex; gap: 0.6rem; align-items: center; }
  .f-editrow .f-input { flex: 1; }
  .f-newbtn { font-family: 'Noto Serif KR', serif; font-size: 0.9rem; color: var(--ink); background: transparent; border: 1px solid var(--rule); border-radius: 4px; padding: 0.7rem 1rem; cursor: pointer; white-space: nowrap; transition: border-color 0.2s, color 0.2s; }
  .f-newbtn:hover { border-color: var(--mark); color: var(--mark); }
  .f-editmode { font-family: 'EB Garamond', serif; font-style: italic; font-size: 0.88rem; color: var(--mark); margin-top: 0.6rem; min-height: 1.2rem; }
  .f-warn { font-family: 'Noto Serif KR', serif; font-size: 0.85rem; color: var(--mark); background: rgba(139,58,46,0.06); border-radius: 4px; padding: 0.6rem 0.8rem; margin: 0.5rem 0 0.3rem; line-height: 1.5; }
  .f-warn code { font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; background: rgba(139,58,46,0.12); padding: 0.05rem 0.3rem; border-radius: 3px; }
  .f-label { font-family: 'Noto Serif KR', serif; font-size: 0.95rem; color: var(--ink); margin: 1.3rem 0 0.4rem; }
  .f-hint { font-family: 'EB Garamond', serif; font-style: italic; font-size: 0.8rem; color: var(--ink-faint); margin-left: 0.4rem; }
  .f-input, .f-textarea { font-family: 'Noto Serif KR', serif; font-size: 1rem; color: var(--ink); background: rgba(255,255,255,0.5); border: 1px solid var(--rule); border-radius: 4px; padding: 0.7rem 0.8rem; width: 100%; }
  .f-input:focus, .f-textarea:focus { outline: none; border-color: var(--mark); }
  .f-textarea { font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; line-height: 1.6; resize: vertical; }
  .ed-bar { display: flex; align-items: center; justify-content: space-between; gap: 0.6rem; margin-bottom: 0.5rem; flex-wrap: wrap; }
  .ed-tools { display: flex; gap: 0.2rem; flex-wrap: wrap; align-items: center; }
  .ed-tools button { font-family: 'Noto Serif KR', serif; font-size: 0.9rem; color: var(--ink); background: transparent; border: 1px solid var(--rule); border-radius: 3px; padding: 0.35rem 0.6rem; cursor: pointer; min-width: 2rem; transition: border-color 0.15s, color 0.15s; }
  .ed-tools button:hover { border-color: var(--mark); color: var(--mark); }
  .ed-tools button.is-active { border-color: var(--mark); color: var(--mark); background: rgba(139,58,46,0.08); }
  .ed-sep { width: 1px; height: 1.2rem; background: var(--rule); margin: 0 0.3rem; }
  .ed-source-toggle { font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; color: var(--ink-soft); background: transparent; border: 1px solid var(--rule); border-radius: 3px; padding: 0.35rem 0.6rem; cursor: pointer; white-space: nowrap; transition: border-color 0.15s, color 0.15s; }
  .ed-source-toggle:hover { border-color: var(--mark); color: var(--mark); }
  .ed-source-toggle.is-active { border-color: var(--mark); color: var(--mark); background: rgba(139,58,46,0.08); }
  .ed-editor { border: 1px solid var(--rule); border-radius: 4px; background: rgba(255,255,255,0.5); padding: 0.9rem 1rem; min-height: 300px; }
  .ed-editor:focus-within { border-color: var(--mark); }
  .ed-editor .ProseMirror { outline: none; font-family: 'Noto Serif KR', serif; font-size: 1rem; line-height: 1.8; color: var(--ink); }
  .ed-editor .ProseMirror > * { margin: 0 0 1rem; }
  .ed-editor .ProseMirror h2 { font-size: 1.4rem; font-weight: 600; margin: 1.4rem 0 0.7rem; }
  .ed-editor .ProseMirror h3 { font-size: 1.2rem; font-weight: 600; margin: 1.2rem 0 0.6rem; }
  .ed-editor .ProseMirror blockquote { border-left: 2px solid var(--mark); padding-left: 1rem; color: var(--ink-soft); font-style: italic; }
  .ed-editor .ProseMirror ul, .ed-editor .ProseMirror ol { padding-left: 1.5rem; }
  .ed-editor .ProseMirror img { max-width: 100%; border-radius: 4px; }
  .ed-editor :global(.ProseMirror img) { display: block; height: auto; }
  .ed-editor :global(.ProseMirror img[data-size="xs"]) { max-width: 25%; }
  .ed-editor :global(.ProseMirror img[data-size="sm"]) { max-width: 40%; }
  .ed-editor :global(.ProseMirror img[data-size="md"]) { max-width: 60%; }
  .ed-editor :global(.ProseMirror img[data-size="lg"]) { max-width: 80%; }
  .ed-editor :global(.ProseMirror img[data-size="full"]) { max-width: 100%; }
  .ed-editor :global(.ProseMirror img[data-align="left"]) { margin-right: auto; margin-left: 0; }
  .ed-editor :global(.ProseMirror img[data-align="center"]) { margin-left: auto; margin-right: auto; }
  .ed-editor :global(.ProseMirror img[data-align="right"]) { margin-left: auto; margin-right: 0; }
  .ed-imgalign:disabled { opacity: 0.3; cursor: default; }
  .ed-imgcaption:disabled { opacity: 0.3; cursor: default; }
  .ed-imgungroup:disabled { opacity: 0.3; cursor: default; }
  .ed-imgungroup:disabled:hover { border-color: var(--rule); color: var(--ink); }
  .ed-imgcaption:disabled:hover { border-color: var(--rule); color: var(--ink); }
  .ed-editor :global(.ProseMirror figure) { margin: 1rem 0; }
  .ed-editor :global(.ProseMirror figure[data-size="xs"]) { max-width: 25%; }
  .ed-editor :global(.ProseMirror figure[data-size="sm"]) { max-width: 40%; }
  .ed-editor :global(.ProseMirror figure[data-size="md"]) { max-width: 60%; }
  .ed-editor :global(.ProseMirror figure[data-size="lg"]) { max-width: 80%; }
  .ed-editor :global(.ProseMirror figure[data-size="full"]) { max-width: 100%; }
  .ed-editor :global(.ProseMirror figure[data-align="left"]) { margin-right: auto; margin-left: 0; }
  .ed-editor :global(.ProseMirror figure[data-align="center"]) { margin-left: auto; margin-right: auto; }
  .ed-editor :global(.ProseMirror figure[data-align="right"]) { margin-left: auto; margin-right: 0; }
  .ed-editor :global(.ProseMirror figure img) { display: block; max-width: 100%; height: auto; }
  .ed-editor :global(.ProseMirror figcaption) { font-size: 0.82rem; color: var(--ink-soft); margin-top: 0.4rem; line-height: 1.5; }
  .ed-editor :global(.ProseMirror figure[data-align="left"] figcaption) { text-align: left; }
  .ed-editor :global(.ProseMirror figure[data-align="center"] figcaption) { text-align: center; }
  .ed-editor :global(.ProseMirror figure[data-align="right"] figcaption) { text-align: right; }
  .ed-editor :global(.ProseMirror div[data-nm-group]) { margin: 1rem 0; }
  .ed-editor :global(.ProseMirror div[data-nm-group][data-size="xs"]) { max-width: 40%; }
  .ed-editor :global(.ProseMirror div[data-nm-group][data-size="sm"]) { max-width: 55%; }
  .ed-editor :global(.ProseMirror div[data-nm-group][data-size="md"]) { max-width: 70%; }
  .ed-editor :global(.ProseMirror div[data-nm-group][data-size="lg"]) { max-width: 85%; }
  .ed-editor :global(.ProseMirror div[data-nm-group][data-size="full"]) { max-width: 100%; }
  .ed-editor :global(.ProseMirror div[data-nm-group][data-align="left"]) { margin-right: auto; margin-left: 0; }
  .ed-editor :global(.ProseMirror div[data-nm-group][data-align="center"]) { margin-left: auto; margin-right: auto; }
  .ed-editor :global(.ProseMirror div[data-nm-group][data-align="right"]) { margin-left: auto; margin-right: 0; }
  .ed-editor :global(.ProseMirror div[data-nm-group-row]) { display: flex; gap: 0.5rem; }
  .ed-editor :global(.ProseMirror div[data-nm-group-row] img) { width: 50%; height: auto; object-fit: cover; display: block; margin: 0; max-width: none; }
  .ed-editor :global(.ProseMirror div[data-nm-group] figcaption) { display: flex; gap: 0.5rem; margin-top: 0.4rem; font-size: 0.82rem; color: var(--ink-soft); line-height: 1.5; }
  .ed-editor :global(.ProseMirror div[data-nm-group] figcaption span) { width: 50%; text-align: center; }
  .ed-editor :global(.ProseMirror div[data-nm-group].ProseMirror-selectednode) { outline: 2px solid var(--mark); outline-offset: 2px; }
  .ed-imgalign:disabled:hover { border-color: var(--rule); color: var(--ink); }
  .ed-editor :global(.ProseMirror img.ProseMirror-selectednode) { outline: 2px solid var(--mark); outline-offset: 2px; }
  .ed-imgsize:disabled { opacity: 0.3; cursor: default; }
  .ed-imgsize:disabled:hover { border-color: var(--rule); color: var(--ink); }
  .ed-editor .ProseMirror blockquote p, .ed-editor .ProseMirror li p { margin: 0; }
  .ed-editor .ProseMirror p.is-editor-empty:first-child::before { content: attr(data-placeholder); color: var(--ink-faint); float: left; height: 0; pointer-events: none; }
  .f-topic-modes { display: flex; gap: 1.4rem; margin: 0.5rem 0 0.3rem; flex-wrap: wrap; }
  .f-radio { font-family: 'Noto Serif KR', serif; font-size: 0.92rem; color: var(--ink); display: flex; align-items: center; gap: 0.4rem; cursor: pointer; }
  .f-topic-new { border: 1px dashed var(--rule); border-radius: 4px; padding: 0.2rem 0.9rem 0.9rem; margin-top: 0.4rem; }
  .f-details { margin-top: 1.3rem; border: 1px dashed var(--rule); border-radius: 4px; padding: 0.4rem 0.9rem; }
  .f-details summary { font-family: 'Noto Serif KR', serif; font-size: 0.9rem; color: var(--ink-soft); cursor: pointer; padding: 0.4rem 0; }
  .f-row { display: flex; gap: 2rem; align-items: flex-end; margin-top: 0.4rem; }
  .f-row > div { flex: 1; }
  .f-check { font-family: 'Noto Serif KR', serif; font-size: 0.95rem; color: var(--ink); display: flex; align-items: center; gap: 0.4rem; padding-bottom: 0.7rem; white-space: nowrap; }
  .f-save { font-family: 'Noto Serif KR', serif; font-size: 1.05rem; color: #fff; background: var(--mark); border: none; border-radius: 4px; padding: 0.9rem; margin-top: 2rem; cursor: pointer; transition: opacity 0.2s; }
  .f-save:hover { opacity: 0.85; }
  .f-save:disabled { opacity: 0.4; cursor: default; }
  .f-result { font-family: 'EB Garamond', serif; font-size: 0.95rem; margin-top: 1rem; min-height: 1.4rem; }
</style>

<script>
  import { supabase } from '../../lib/supabaseClient.js';
  import { preprocessBody } from '../../lib/editor/anchor-client.js';
  import { initDeskEditor, setUploadToken } from '../../lib/editor/desk-editor.js';

  // NOTE: works.week = '넘기' 번호 (발행 회차, 1부터 누적, 쉬어가도 연속). 달력 주차·week 표기는 독자에게 노출 금지 — 표기는 'N번째 넘기'.

  function slugify(s) {
    return (s || '').trim().toLowerCase()
      .replace(/\s+/g, '-')
      .replace(/[^a-z0-9가-힣\-]/g, '')
      .replace(/\-+/g, '-')
      .replace(/^\-+|\-+$/g, '');
  }

  function getTopicMode() {
    const r = document.querySelector('input[name="topic-mode"]:checked');
    return r ? r.value : 'solo';
  }

  function updateTopicUI() {
    const mode = getTopicMode();
    const solo = document.getElementById('topic-solo');
    const existing = document.getElementById('topic-existing');
    const nw = document.getElementById('topic-new');
    if (solo) solo.style.display = (mode === 'solo') ? 'block' : 'none';
    if (existing) existing.style.display = (mode === 'existing') ? 'block' : 'none';
    if (nw) nw.style.display = (mode === 'new') ? 'block' : 'none';
  }

  async function loadWorks() {
    const sel = document.getElementById('f-workid');
    if (!sel) return;
    try {
      const { data: works } = await supabase
        .from('works')
        .select('id, week, category, title')
        .order('week', { ascending: false });
      if (!works || works.length === 0) {
        sel.innerHTML = '<option value="">(아직 주제 카드가 없습니다)</option>';
        return;
      }
      sel.innerHTML = works.map(w =>
        '<option value="' + w.id + '">' + w.week + '번째 넘기 · ' + w.category + ' · ' + w.title + '</option>'
      ).join('');

      // 넘기 번호 자동 제안: 직전 최대 넘기 + 1 (works가 week 내림차순이라 [0]이 최대). 수정 가능한 기본값.
      const nwWeekEl = document.getElementById('f-nw-week');
      if (nwWeekEl && !nwWeekEl.value) {
        const maxWeek = works[0] ? Number(works[0].week) : 0;
        if (Number.isFinite(maxWeek)) nwWeekEl.value = String(maxWeek + 1);
      }
    } catch (e) {
      sel.innerHTML = '<option value="">(목록을 불러오지 못했습니다)</option>';
    }
  }

  // ===== 기존 글 수정 =====
  let editingId = null;  // 수정 중인 글 id (null이면 신규)
  let deskToken = null;  // 서버 함수 호출용 access_token

  // 발행된(그리고 초안 포함) 글 목록을 select에 채움
  async function loadArticleList() {
    const sel = document.getElementById('f-editpick');
    if (!sel) return;
    try {
      const res = await fetch('/.netlify/functions/list-articles', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token: deskToken, action: 'list' }),
      });
      const data = await res.json();
      if (data.status !== 'ok') {
        sel.innerHTML = '<option value="">(목록을 불러오지 못했습니다)</option>';
        return;
      }
      const opts = ['<option value="">— 새 글 쓰기 —</option>'];
      (data.articles || []).forEach(a => {
        const mark = a.status === 'published' ? '' : ' [' + a.status + ']';
        opts.push('<option value="' + a.id + '">' + (a.title || '(제목 없음)') + mark + '</option>');
      });
      sel.innerHTML = opts.join('');
      if (editingId) sel.value = String(editingId);
    } catch (e) {
      sel.innerHTML = '<option value="">(목록을 불러오지 못했습니다)</option>';
    }
  }

  // 폼 전체를 비우고 신규 모드로
  function resetToNew() {
    editingId = null;
    const ids = ['f-title','f-subtitle','f-slug','f-tags','f-cover','f-coveralt','f-body','f-metadesc','f-ogimage','f-nw-title','f-nw-slug','f-nw-week'];
    ids.forEach(id => { const el = document.getElementById(id); if (el) el.value = ''; });
    const status = document.getElementById('f-status'); if (status) status.value = 'draft';
    const pinned = document.getElementById('f-pinned'); if (pinned) pinned.checked = false;
    const warn = document.getElementById('f-bodywarn'); if (warn) warn.style.display = 'none';
    if (deskEditor) deskEditor.setBody('');  // 에디터도 비움 (새 글)
    const mode = document.getElementById('f-editmode'); if (mode) mode.textContent = '';
    const pick = document.getElementById('f-editpick'); if (pick) pick.value = '';
    // 주제 카드 모드는 단독으로 되돌림
    const solo = document.querySelector('input[name="topic-mode"][value="solo"]');
    if (solo) { solo.checked = true; updateTopicUI(); }
  }

  // 선택한 글을 폼에 불러옴 — body는 저장된 그대로(data-anchor 포함) 넣는다 (생명줄)
  async function pickArticle(id) {
    if (!id) { resetToNew(); return; }
    try {
      const res = await fetch('/.netlify/functions/list-articles', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token: deskToken, action: 'get', id: id }),
      });
      const data = await res.json();
      if (data.status !== 'ok' || !data.article) { alert('글을 불러오지 못했습니다.'); return; }
      const art = data.article;

      editingId = art.id;
      const set = (fid, val) => { const el = document.getElementById(fid); if (el) el.value = (val != null ? val : ''); };
      set('f-title', art.title);
      set('f-subtitle', art.subtitle);
      set('f-slug', art.slug);
      set('f-tags', Array.isArray(art.tags) ? art.tags.join(', ') : '');
      set('f-cover', art.cover_image);
      set('f-coveralt', art.cover_alt);
      if (deskEditor) deskEditor.setBody(art.body);   // ★ 앵커 붙은 원본 그대로 (에디터로)
      set('f-metadesc', art.meta_desc);
      set('f-ogimage', art.og_image);
      const status = document.getElementById('f-status'); if (status) status.value = art.status || 'draft';
      const pinned = document.getElementById('f-pinned'); if (pinned) pinned.checked = !!art.pinned;

      // 주제 카드 모드 설정: work_id 있으면 기존카드, 없으면 단독(공지 등)
      if (art.work_id) {
        const ex = document.querySelector('input[name="topic-mode"][value="existing"]');
        if (ex) { ex.checked = true; updateTopicUI(); }
        const wsel = document.getElementById('f-workid');
        if (wsel) wsel.value = String(art.work_id);
      } else {
        const solo = document.querySelector('input[name="topic-mode"][value="solo"]');
        if (solo) { solo.checked = true; updateTopicUI(); }
        const cat = document.getElementById('f-category');
        if (cat && art.category) cat.value = art.category;
      }

      // 수정 모드 표시 + 주의 문구 켬
      const mode = document.getElementById('f-editmode');
      if (mode) mode.textContent = '수정 중: ' + (art.title || '(제목 없음)') + ' (/' + art.slug + ')';
      const warn = document.getElementById('f-bodywarn');
      if (warn) warn.style.display = 'block';

      window.scrollTo({ top: 0, behavior: 'smooth' });
    } catch (e) {
      alert('불러오기 실패: ' + e.message);
    }
  }

  let deskEditor = null;  // 리치 에디터 핸들 (getBody/setBody)

  async function initDesk() {
    const wrap = document.getElementById('desk-wrap');
    const note = document.getElementById('desk-note');
    const form = document.getElementById('desk-form');
    if (wrap) wrap.style.opacity = '1';

    let session = null;
    try {
      const { data } = await supabase.auth.getSession();
      session = data ? data.session : null;
    } catch (e) {}
    if (!session) { window.location.href = '/'; return; }

    // 리치 에디터 초기화 (2층)
    deskEditor = initDeskEditor();
    setUploadToken(session.access_token);  // 이미지 업로드용 operator 토큰 주입

    let isAdmin = false;
    try {
      const res = await fetch('/.netlify/functions/admin-check', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token: session.access_token }),
      });
      const data = await res.json();
      isAdmin = !!data.admin;
    } catch (e) {}
    if (!isAdmin) { window.location.href = '/'; return; }

    if (note) note.textContent = '글을 씁니다.';
    if (form) form.style.display = 'flex';

    // 주제 카드 모드 전환
    document.querySelectorAll('input[name="topic-mode"]').forEach(r => {
      r.addEventListener('change', updateTopicUI);
    });
    updateTopicUI();
    loadWorks();

    // 기존 글 수정 동선
    deskToken = session.access_token;
    loadArticleList();
    const pickEl = document.getElementById('f-editpick');
    if (pickEl) pickEl.addEventListener('change', () => pickArticle(pickEl.value));
    const newBtn = document.getElementById('f-newbtn');
    if (newBtn) newBtn.addEventListener('click', resetToNew);

    // 글 제목 → 글 slug 자동
    const titleEl = document.getElementById('f-title');
    const slugEl = document.getElementById('f-slug');
    let slugTouched = false;
    if (slugEl) slugEl.addEventListener('input', () => { slugTouched = true; });
    if (titleEl && slugEl) {
      titleEl.addEventListener('input', () => {
        if (!slugTouched) slugEl.value = slugify(titleEl.value);
      });
    }

    // 새 주제 카드 제목 → 주제 slug 자동
    const nwTitleEl = document.getElementById('f-nw-title');
    const nwSlugEl = document.getElementById('f-nw-slug');
    let nwSlugTouched = false;
    if (nwSlugEl) nwSlugEl.addEventListener('input', () => { nwSlugTouched = true; });
    if (nwTitleEl && nwSlugEl) {
      nwTitleEl.addEventListener('input', () => {
        if (!nwSlugTouched) nwSlugEl.value = slugify(nwTitleEl.value);
      });
    }

    deskToken = session.access_token;
    setupSave(session);
  }

  // 본문 HTML 구조 건전성 검증 (마틴: 클라이언트 DOMParser, 2단 방어의 앞단)
  // 입력 HTML을 브라우저가 파싱→재직렬화한 결과와 원본을 정규화 비교.
  // 브라우저가 "보정"했다면 = 원본 구조가 깨져 있었다는 뜻 → 저장 중단.
  function checkBodyStructure(html) {
    // 정규화: 태그 사이 공백 차이 등 무해한 차이는 흡수
    const normalize = (s) => s
      .replace(/\s+/g, ' ')           // 연속 공백 → 하나
      .replace(/>\s+</g, '><')        // 태그 사이 공백 제거
      .replace(/\s+>/g, '>')          // 태그 닫기 앞 공백
      .trim();

    // 브라우저 파서로 파싱 후 재직렬화
    const doc = new DOMParser().parseFromString('<div id="__wrap__">' + html + '</div>', 'text/html');
    const wrap = doc.getElementById('__wrap__');
    if (!wrap) return { ok: false, reason: '파싱 실패' };
    const reserialized = wrap.innerHTML;

    const a = normalize(html);
    const b = normalize(reserialized);

    if (a === b) return { ok: true };
    return { ok: false, reason: '구조 불일치', original: a, corrected: b };
  }

  function setupSave(session) {
    const btn = document.getElementById('f-save');
    const result = document.getElementById('f-result');
    if (!btn) return;

    btn.addEventListener('click', async () => {
      const get = (id) => {
        const el = document.getElementById(id);
        return el ? el.value.trim() : '';
      };
      const tagsRaw = get('f-tags');
      const tags = tagsRaw ? tagsRaw.split(',').map(t => t.trim()).filter(Boolean) : [];

      const article = {
        title: get('f-title'),
        subtitle: get('f-subtitle'),
        slug: get('f-slug'),
        tags: tags,
        cover_image: get('f-cover'),
        cover_alt: get('f-coveralt'),
        body: deskEditor ? deskEditor.getBody() : get('f-body'),
        meta_desc: get('f-metadesc'),
        og_image: get('f-ogimage'),
        status: get('f-status'),
        pinned: document.getElementById('f-pinned').checked,
      };

      // 주제 카드 모드별 처리
      const mode = getTopicMode();
      if (mode === 'solo') {
        article.category = get('f-category');
      } else if (mode === 'existing') {
        const wid = get('f-workid');
        if (!wid) { showErr('주제 카드를 선택하십시오.'); return; }
        article.work_id = parseInt(wid, 10);
      } else if (mode === 'new') {
        const nwTitle = get('f-nw-title');
        const nwSlug = get('f-nw-slug');
        const nwWeek = get('f-nw-week');
        if (!nwTitle || !nwSlug || !nwWeek) { showErr('새 주제 카드의 넘기 번호·제목·주소를 채우십시오.'); return; }
        article.newWork = {
          week: nwWeek,
          category: get('f-nw-category'),
          title: nwTitle,
          slug: nwSlug,
        };
      }

      // 수정 모드면 id를 실어 보냄 (신규면 insert)
      if (editingId) article.id = editingId;

      function showErr(msg) {
        if (result) { result.style.color = '#a33'; result.textContent = msg; }
      }

      if (!article.title || !article.body || !article.slug) {
        showErr('제목·주소·본문은 비울 수 없습니다.');
        return;
      }

      // 본문 구조 건전성 검증 (저장 전, 클라이언트 방어선)
      const struct = checkBodyStructure(article.body);
      if (!struct.ok) {
        showErr('본문 HTML 구조에 문제가 있어 저장을 중단했습니다 (태그가 안 닫혔거나 잘못 중첩됨). 확인 후 다시 저장하세요.');
        console.log('구조 검증 실패 — 원본:', struct.original);
        console.log('구조 검증 실패 — 브라우저 보정:', struct.corrected);
        return;
      }

      // 본문 전처리 (마틴 파이프라인: 빈 블록 제거 → 앵커 주입). 결과를 body로.
      const prep = preprocessBody(article.body);
      article.body = prep.html;
      if (prep.removed > 0) {
        console.log('빈 블록 ' + prep.removed + '개 제거됨 (저장 전 전처리)');
      }
      if (prep.removed > 0) {
        console.log('빈 블록 ' + prep.removed + '개 제거됨 (저장 전 전처리)');
      }

      btn.disabled = true;
      if (result) { result.style.color = 'var(--ink-soft)'; result.textContent = '저장하는 중...'; }

      try {
        const res = await fetch('/.netlify/functions/save-article', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token: session.access_token, article })
        });
        const data = await res.json();
        if (data.status === 'ok') {
          const wasEdit = !!editingId;
          if (result) {
            result.style.color = 'var(--mark)';
            result.textContent = (wasEdit ? '수정되었습니다' : '저장되었습니다') + '. (주소: /' + data.slug + ')';
          }
          if (data.id) editingId = data.id;
          loadWorks();
          loadArticleList();
        } else if (data.status === 'forbidden') {
          showErr('권한이 없습니다.');
        } else {
          showErr('오류: ' + (data.detail || '알 수 없음'));
        }
      } catch (e) {
        showErr('저장 실패: ' + e.message);
      }
      btn.disabled = false;
    });
  }

  if (document.readyState !== 'loading') initDesk();
  else document.addEventListener('DOMContentLoaded', initDesk);
  document.addEventListener('astro:page-load', initDesk);
</script>
