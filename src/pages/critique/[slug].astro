---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Masthead from '../../components/Masthead.astro';
import { getCollection, render } from 'astro:content';
export async function getStaticPaths() {
  const items = await getCollection('critiques');
  return items.map(item => ({ params: { slug: item.id }, props: { item } }));
}
const { item } = Astro.props;
const { Content } = await render(item);
---
<BaseLayout title={item.data.title + ' — 비평 — Nuh-Muh'}>
  <div class="container">
    <Masthead />
    <article class="cp">
      <a href="/critique" class="back">← 비평 목록</a>
      <span class="kicker">비평</span>
      <h1>{item.data.title}</h1>
      <div class="body"><Content /></div>
    </article>
  </div>
</BaseLayout>
<style>
  .cp { max-width: 720px; margin: 0 auto; padding: 2rem 0 6rem; }
  .back { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; letter-spacing: 0.15em; color: var(--ink-soft); text-decoration: none; display: inline-block; margin-bottom: 3rem; }
  .back:hover { color: var(--mark); }
  .kicker { font-family: 'JetBrains Mono', monospace; font-size: 0.66rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--mark); }
  .cp h1 { font-family: 'Noto Serif KR', serif; font-weight: 500; font-size: 2.6rem; margin: 0.8rem 0 2rem; line-height: 1.2; border-bottom: 1px solid var(--rule-strong); padding-bottom: 2rem; }
  .body { font-family: 'Noto Serif KR', serif; line-height: 1.9; color: var(--ink); }
</style>
