<style>
  .crk {
    position: fixed; left: 0.6rem; top: 72%;
    transform: translateY(-50%);
    width: 112px; height: 112px;
    z-index: 70; display: none;
  }
  .crk.unlocked { display: block; }
  .crk-inner { position: absolute; inset: 0; overflow: hidden; border-radius: 50%; background: #f2ecd9; }

  .crk-throat { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; overflow: hidden; background: #f2ecd9; border-radius: 50%; }
  /* 굵은 흑백 나선: repeating-conic + 회전으로 소용돌이 */
  .crk-swirl {
    width: 122%; height: 122%;
    flex-shrink: 0;
    opacity: 0;
    transition: opacity 0.5s;
    animation: crk-spin 4s linear infinite;
    transform-origin: center;
  }
  @keyframes crk-spin { to { transform: rotate(-360deg); } }

  .shard {
    position: absolute; top: -6%; height: 112%; width: 130%;
    fill: var(--paper); stroke: var(--ink); stroke-width: 1.2;
    transition: transform 1.1s cubic-bezier(0.34, 1.3, 0.64, 1);
    z-index: 2;
  }
  .shard-left { left: -15%; }
  .shard-right { left: -15%; }
  .crk:hover .shard-left { transform: translateX(-100%); }
  .crk:hover .shard-right { transform: translateX(100%); }
  .crk:hover .crk-swirl { opacity: 1; }

  /* 등장 연출: 위→아래로 찌지직 드러남 (세션당 1회) */
  .crk.revealing .crk-inner {
    animation: crk-reveal 1.7s ease-out both;
  }
  @keyframes crk-reveal {
    0%   { clip-path: inset(0 0 100% 0); transform: translateX(0); }
    9%   { clip-path: inset(0 0 87% 0);  transform: translateX(-1px); }
    15%  { clip-path: inset(0 0 85% 0);  transform: translateX(1px); }
    29%  { clip-path: inset(0 0 63% 0);  transform: translateX(-1px); }
    35%  { clip-path: inset(0 0 61% 0);  transform: translateX(1.5px); }
    51%  { clip-path: inset(0 0 38% 0);  transform: translateX(-1px); }
    57%  { clip-path: inset(0 0 36% 0);  transform: translateX(1px); }
    73%  { clip-path: inset(0 0 15% 0);  transform: translateX(-1.5px); }
    79%  { clip-path: inset(0 0 13% 0);  transform: translateX(1px); }
    100% { clip-path: inset(0 0 0 0);    transform: translateX(0); }
  }

  @media (max-width: 900px) { .crk { display: none !important; } }
</style>

<script>
  import { supabase } from '../lib/supabaseClient.js';
  async function initCrk() {
    const el = document.getElementById('discord-crack');
    if (!el) return;
    let loggedIn = false;
    try {
      const { data } = await supabase.auth.getSession();
      loggedIn = !!(data && data.session);
    } catch (e) {}
    el.classList.toggle('unlocked', loggedIn);

    if (loggedIn) {
      let revealed = false;
      try { revealed = sessionStorage.getItem('nuhmuh_crack_revealed') === 'true'; } catch (e) {}
      if (!revealed) {
        el.classList.add('revealing');
        try { sessionStorage.setItem('nuhmuh_crack_revealed', 'true'); } catch (e) {}
        el.addEventListener('animationend', () => el.classList.remove('revealing'), { once: true });
      }
    } else {
      el.classList.remove('revealing');
      try { sessionStorage.removeItem('nuhmuh_crack_revealed'); } catch (e) {}
    }
  }
  if (document.readyState !== 'loading') initCrk();
  else document.addEventListener('DOMContentLoaded', initCrk);
  document.addEventListener('astro:page-load', initCrk);
</script>
