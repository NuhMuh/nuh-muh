---
// 관리자 전용 깃펜 버튼. fixed 좌상단. admin-check로 관리자일 때만 표시.
---
<button class="quill-btn" id="quill-btn" aria-label="발행소" title="발행소">
  <svg class="quill-svg" viewBox="0 0 80 100" aria-hidden="true">
    <!-- 잉크병 -->
    <g class="inkpot">
      <path class="pot-body" d="M22 66 Q20 62 24 60 L56 60 Q60 62 58 66 L56 92 Q56 96 52 96 L28 96 Q24 96 24 92 Z"
        fill="var(--ink)" stroke="var(--ink)" stroke-width="1"/>
      <rect class="pot-neck" x="32" y="54" width="16" height="8" rx="2"
        fill="var(--ink)"/>
      <ellipse class="pot-mouth" cx="40" cy="54" rx="9" ry="3"
        fill="#0a0c14"/>
    </g>
    <!-- 깃펜 (깃털 + 펜대) -->
    <g class="quill">
      <path class="quill-shaft" d="M40 56 L58 14"
        stroke="var(--ink)" stroke-width="2.2" stroke-linecap="round"/>
      <path class="quill-feather" d="M58 14 Q66 18 60 26 Q54 22 58 14 Z M56 20 Q63 24 57 31 Q51 28 56 20 Z M54 27 Q60 31 55 37 Q49 34 54 27 Z"
        fill="var(--mark)" stroke="var(--mark)" stroke-width="0.5"/>
    </g>
  </svg>
  <span class="quill-hint">발행소</span>
</button>

<style>
  .quill-btn {
    position: fixed;
    left: 1.4rem; top: 1.4rem;
    z-index: 90;
    width: 56px; height: 70px;
    background: none; border: none; padding: 0;
    cursor: pointer;
    display: none;                /* 평소 숨김 — 관리자 확인되면 .is-admin로 표시 */
  }
  .quill-btn.is-admin { display: block; }

  .quill-svg { width: 100%; height: 100%; display: block; overflow: visible; }

  /* 깃펜: 평소 잉크병에 꽂혀 있다가, 호버하면 위로 쏙 빠지며 살짝 기욺 */
  .quill {
    transform-origin: 40px 56px;
    transition: transform 0.5s cubic-bezier(0.34, 1.4, 0.64, 1);
  }
  .quill-btn:hover .quill {
    transform: translate(6px, -14px) rotate(8deg);
  }

  /* 잉크병 입구 살짝 어두워짐(펜 빠진 자리) */
  .pot-mouth { transition: fill 0.4s; }
  .quill-btn:hover .pot-mouth { fill: #050608; }

  /* 힌트 글자 */
  .quill-hint {
    position: absolute; left: 50%; bottom: -1.4rem;
    transform: translateX(-50%);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.54rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--ink-faint); white-space: nowrap;
    opacity: 0; transition: opacity 0.4s;
  }
  .quill-btn:hover .quill-hint { opacity: 1; }

  @media (max-width: 900px) { .quill-btn { left: 0.8rem; top: 0.8rem; } }
</style>

<script>
  import { supabase } from '../lib/supabaseClient.js';

  async function initQuill() {
    const btn = document.getElementById('quill-btn');
    if (!btn) return;

    // 1) 세션 확인 — 로그인 안 했으면 끝(숨김 유지)
    let session = null;
    try {
      const { data } = await supabase.auth.getSession();
      session = data ? data.session : null;
    } catch (e) {}
    if (!session) { btn.classList.remove('is-admin'); return; }

    // 2) 관리자 판정 — 서버에 토큰 보내 확인
    let isAdmin = false;
    try {
      const res = await fetch('/.netlify/functions/admin-check', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token: session.access_token }),
      });
      const data = await res.json();
      isAdmin = !!data.admin;
    } catch (e) {}

    btn.classList.toggle('is-admin', isAdmin);

    // 3) 클릭 → 발행소
    if (isAdmin && !btn.dataset.bound) {
      btn.dataset.bound = 'true';
      btn.addEventListener('click', function () {
        window.location.href = '/desk';
      });
    }
  }

  if (document.readyState !== 'loading') initQuill();
  else document.addEventListener('DOMContentLoaded', initQuill);
  document.addEventListener('astro:page-load', initQuill);
</script>
