---
// 관리자 전용 깃펜 버튼. fixed 좌상단. admin-check로 관리자일 때만 표시.
---
<button class="quill-btn" id="quill-btn" aria-label="발행소" title="발행소">
  <div class="quill-reveal">
    <svg class="quill-svg" viewBox="0 0 80 100" aria-hidden="true">
      <!-- 잉크병 -->
      <g class="inkpot">
        <path class="pot-body" d="M22 66 Q20 62 24 60 L56 60 Q60 62 58 66 L56 92 Q56 96 52 96 L28 96 Q24 96 24 92 Z"
          fill="var(--ink)" stroke="var(--ink)" stroke-width="1"/>
        <rect class="pot-neck" x="32" y="54" width="16" height="8" rx="2"
          fill="var(--ink)"/>
        <ellipse class="pot-mouth" cx="40" cy="54" rx="9" ry="3"
          fill="#0a0c14"/>
      </g>
      <!-- 깃펜 -->
      <g class="quill">
        <!-- 펜대(깃대) -->
        <path class="quill-shaft" d="M40 58 Q49 38 62 10"
          stroke="var(--ink)" stroke-width="2" stroke-linecap="round" fill="none"/>
        <!-- 깃털: 깃대 양옆으로 갈라진 깃가지들 -->
        <g class="quill-barbs" stroke="var(--mark)" stroke-width="1.1" stroke-linecap="round" fill="none">
          <path d="M58 17 Q63 15 66 11 M57 20 Q62 19 65 15 M55 24 Q61 23 64 20 M54 27 Q59 27 62 24 M52 31 Q57 31 60 29 M51 34 Q56 35 58 33"/>
          <path d="M59 16 Q56 12 57 8 M57 21 Q54 18 55 13 M56 25 Q53 22 53 18 M54 28 Q51 26 51 22"/>
        </g>
      </g>
    </svg>
  </div>
</button>

<style>
  .quill-btn {
    position: fixed;
    left: 1.4rem; top: 1.4rem;
    z-index: 90;
    width: 56px; height: 70px;
    background: none; border: none; padding: 0;
    cursor: pointer;
    display: none;                /* 평소 숨김 — 관리자 확인되면 .is-admin로 표시 */
  }
  .quill-btn.is-admin { display: block; }

  /* 등장 연출용 래퍼 — 아래→위로 드러남 */
  .quill-reveal { width: 100%; height: 100%; }
  .quill-btn.revealing .quill-reveal {
    animation: quill-rise 1.5s ease-out both;
  }
  @keyframes quill-rise {
    0%   { clip-path: inset(100% 0 0 0); }
    9%   { clip-path: inset(88% 0 0 0); }
    20%  { clip-path: inset(72% 0 0 0); }
    35%  { clip-path: inset(55% 0 0 0); }
    52%  { clip-path: inset(38% 0 0 0); }
    73%  { clip-path: inset(16% 0 0 0); }
    100% { clip-path: inset(0 0 0 0); }
  }

  .quill-svg { width: 100%; height: 100%; display: block; overflow: visible; }

  /* 깃펜: 평소 잉크병에 꽂혀 있다가, 호버하면 위로 쏙 빠지며 살짝 기욺 */
  .quill {
    transform-origin: 40px 58px;
    transition: transform 0.5s cubic-bezier(0.34, 1.4, 0.64, 1);
  }
  .quill-btn:hover .quill {
    transform: translate(6px, -14px) rotate(8deg);
  }

  /* 잉크병 입구 살짝 어두워짐(펜 빠진 자리) */
  .pot-mouth { transition: fill 0.4s; }
  .quill-btn:hover .pot-mouth { fill: #050608; }

  @media (max-width: 900px) { .quill-btn { left: 0.8rem; top: 0.8rem; } }
</style>

<script>
  import { supabase } from '../lib/supabaseClient.js';

  async function initQuill() {
    const btn = document.getElementById('quill-btn');
    if (!btn) return;

    let session = null;
    try {
      const { data } = await supabase.auth.getSession();
      session = data ? data.session : null;
    } catch (e) {}
    if (!session) {
      btn.classList.remove('is-admin');
      try { sessionStorage.removeItem('nuhmuh_quill_revealed'); } catch (e) {}
      return;
    }

    let isAdmin = false;
    try {
      const res = await fetch('/.netlify/functions/admin-check', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token: session.access_token }),
      });
      const data = await res.json();
      isAdmin = !!data.admin;
    } catch (e) {}

    if (!isAdmin) {
      btn.classList.remove('is-admin');
      return;
    }

    // 관리자 확인 → 표시
    btn.classList.add('is-admin');

    // 등장 연출: 세션당 1회 (균열·문과 동일 방식)
    let revealed = false;
    try { revealed = sessionStorage.getItem('nuhmuh_quill_revealed') === 'true'; } catch (e) {}
    if (!revealed) {
      btn.classList.add('revealing');
      try { sessionStorage.setItem('nuhmuh_quill_revealed', 'true'); } catch (e) {}
      btn.addEventListener('animationend', () => btn.classList.remove('revealing'), { once: true });
    }

    // 클릭 → 발행소
    if (!btn.dataset.bound) {
      btn.dataset.bound = 'true';
      btn.addEventListener('click', function () {
        window.location.href = '/desk';
      });
    }
  }

  if (document.readyState !== 'loading') initQuill();
  else document.addEventListener('DOMContentLoaded', initQuill);
  document.addEventListener('astro:page-load', initQuill);
</script>
