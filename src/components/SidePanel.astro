---
import CardFan from './CardFan.astro';
import DiscordCrack from './DiscordCrack.astro';
import GothicDoor from './GothicDoor.astro';
---
<aside class="side-panel">
  <div class="sp-item sp-question">
    <button class="question-trigger" id="question-trigger" aria-label="구독 안내 열기">?</button>
    <button class="signup-box" id="signup-box">가입</button>
  </div>
  <div class="sp-item sp-fan"><CardFan /></div>
  <div class="sp-item sp-crack"><DiscordCrack /></div>
  <div class="sp-item sp-gate"><GothicDoor /></div>
</aside>
<style>
  .side-panel {
    grid-column: span 3;
    background: transparent;
    border: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    place-items: center;
    gap: 2.5rem 1.5rem;
    padding: 3.5rem 1rem;
  }
  .sp-item { display: flex; align-items: center; justify-content: center; }
  .sp-question { gap: 0.6rem; }
  .question-trigger {
    width: 5rem; height: 5rem;
    display: flex; align-items: center; justify-content: center;
    background: transparent; border: none; cursor: pointer;
    font-family: 'EB Garamond', serif;
    font-size: 4rem; line-height: 1;
    color: var(--ink-soft);
    transition: color 0.4s, transform 0.4s, text-shadow 0.4s;
    padding: 0;
  }
  .question-trigger:hover {
    color: var(--mark);
    transform: scale(1.15);
    text-shadow: 0 0 16px rgba(139, 58, 46, 0.5);
  }
  .signup-box {
    display: none;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem; letter-spacing: 0.2em; text-transform: uppercase;
    padding: 0.4rem 0.7rem;
    background: var(--ink); color: var(--paper);
    border: none; cursor: pointer;
    transition: background 0.3s;
  }
  .signup-box.visible { display: inline-block; }
  .signup-box:hover { background: var(--mark); }
  /* 카드팬/균열: fixed 해제하되 자기 크기 유지 (relative) */
  .sp-fan :global(.card-fan) {
    position: relative !important;
    left: auto !important; top: auto !important;
    transform: none !important;
  }
  .sp-crack :global(.crk) {
    position: relative !important;
    left: auto !important; top: auto !important;
    transform: none !important;
  }
  .sp-gate :global(.gate) {
    position: relative !important;
    left: auto !important; top: auto !important;
    transform: none !important;
  }
  @media (max-width: 700px) {
    .side-panel { grid-column: span 1; }
  }
</style>

<script>
  // 물음표 이스터에그: 가끔 신비한 기호로 바뀜 (페이지 로드마다 랜덤)
  function initQuestionGlyph() {
    const trigger = document.getElementById('question-trigger');
    if (!trigger) return;
    const GLYPHS = ['✦', '✧', '☽', '⚸', '⚹', '✶'];
    const CHANCE = 0.25; // 25% 확률로 다른 기호
    trigger.textContent = (Math.random() < CHANCE)
      ? GLYPHS[Math.floor(Math.random() * GLYPHS.length)]
      : '?';
  }
  if (document.readyState !== 'loading') initQuestionGlyph();
  else document.addEventListener('DOMContentLoaded', initQuestionGlyph);
  document.addEventListener('astro:page-load', initQuestionGlyph);
</script>
