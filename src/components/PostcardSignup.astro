---
---
<div class="postcard-stage" id="postcard-stage">
  <div class="stage-darken" id="stage-darken"></div>

  <div class="postcard" id="postcard">
    <button class="postcard-close" id="postcard-close" aria-label="닫기">×</button>
    <svg class="pc-frame" viewBox="0 0 400 260" preserveAspectRatio="none" aria-hidden="true">
      <rect x="8" y="8" width="384" height="244" fill="none" stroke="#8a4a2a" stroke-width="1.2" vector-effect="non-scaling-stroke"/>
      <rect x="14" y="14" width="372" height="232" fill="none" stroke="#8a4a2a" stroke-width="0.6" vector-effect="non-scaling-stroke"/>
      <g fill="#8a4a2a" stroke="none">
        <path d="M8 8 L30 8 L8 30 Z"/>
        <path d="M392 8 L392 30 L370 8 Z"/>
        <path d="M8 252 L8 230 L30 252 Z"/>
        <path d="M392 252 L370 252 L392 230 Z"/>
      </g>
    </svg>
    <div class="pc-inner">
      <p class="postcard-text" id="postcard-text"></p>
      <hr class="pc-rule" id="postcard-rule" />
      <form class="postcard-form" id="postcard-form">
        <div class="pc-field">
          <input type="email" id="postcard-email" required autocomplete="off" />
          <span class="pc-ph" id="postcard-ph" aria-hidden="true"><em>거미</em>가 찾아갈 <em>이메일</em>을 남기시오</span>
        </div>
        <button type="submit" class="postcard-submit" id="postcard-submit">놓는다</button>
      </form>
      <p class="postcard-already" id="postcard-already">이미 한 번 다녀가셨습니다.</p>
    </div>
  </div>

  <div class="split-line" id="split-line" aria-hidden="true"></div>
  <div class="split-half split-left" id="split-left" aria-hidden="true"></div>
  <div class="split-half split-right" id="split-right" aria-hidden="true"></div>

  <div class="login-box" id="login-box">
    <button class="login-close" id="login-close" aria-label="닫기">×</button>
    <p class="login-title">열쇠를 맞춰 주십시오.</p>
    <input type="email" id="login-email" autocomplete="off" readonly />
    <input type="password" id="login-pass" placeholder="봉인 (비밀번호)" autocomplete="off" required />
    <button type="button" class="postcard-submit" id="login-submit">연다</button>
    <p class="login-msg" id="login-msg"></p>
  </div>

  <div class="spider-rig" id="spider-rig" aria-hidden="true">
    <div class="thread"></div>
    <div class="spider"><img src="/images/spider.png" alt="" /></div>
    <div class="carried-postcard" id="carried-postcard"></div>
  </div>

  <div class="residue" id="residue" aria-hidden="true">
    <svg class="feather" viewBox="0 0 40 80" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M20 4 Q12 40 16 74 M20 4 Q28 40 16 74 M20 20 L12 28 M20 30 L28 36 M20 42 L12 48 M20 52 L26 58"/>
    </svg>
    <svg class="screw" viewBox="0 0 30 60" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M11 4 L19 4 L19 30 L15 40 L11 30 Z"/>
      <path d="M11 10 L19 10 M11 16 L19 16 M11 22 L19 22"/>
    </svg>
  </div>
</div>

<style>
  .postcard-stage {
    position: fixed; inset: 0; z-index: 300;
    opacity: 0; pointer-events: none;
    transition: opacity 0.4s ease;
  }
  .postcard-stage.open { opacity: 1; pointer-events: auto; }

  .stage-darken {
    position: absolute; inset: 0;
    background: rgba(20, 18, 14, 0);
    backdrop-filter: blur(0px);
    transition: background 0.7s ease, backdrop-filter 0.7s ease;
  }
  .stage-darken.darkened {
    background: rgba(20, 18, 14, 0.55);
    backdrop-filter: blur(2px);
  }

  .postcard {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    container-type: inline-size;
    width: calc(100% - 3rem); max-width: 540px;
    background: var(--paper);
    border: none;
    padding: 2.6rem 2.4rem;
    text-align: center;
    box-shadow: 0 30px 70px rgba(28, 35, 64, 0.28);
    transition: transform 1s cubic-bezier(0.5, 0, 0.75, 0), opacity 0.5s ease;
    z-index: 2;
  }
  .postcard::before {
    content: ''; position: absolute; inset: 0; pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    opacity: 0.05; mix-blend-mode: multiply;
  }
  .postcard.taken {
    transform: translate(-50%, -110vh) rotate(-3deg);
    transition: transform 1.1s cubic-bezier(0.5, 0, 0.75, 0);
  }
  .postcard.grabbed {
    transform: translate(-50%, -50%) scale(0.97);
    transition: transform 0.25s ease;
  }

  .postcard-close {
    position: absolute; top: 1rem; right: 1.2rem;
    background: none; border: none;
    font-family: 'EB Garamond', serif; font-size: 1.4rem;
    color: var(--ink-soft); cursor: pointer; line-height: 1;
    transition: color 0.3s, transform 0.3s;
  }
  .postcard-close:hover { color: var(--mark); transform: rotate(90deg); }

  /* ── 빈티지 프레임 (V1: 이중선 + 채운 모서리 삼각형) ── */
  .pc-frame {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    pointer-events: none; z-index: 1;
  }
  .pc-inner { position: relative; z-index: 2; }

  /* 소개문 아래 붉은 가로선 — 카드 내 유일한 붉은색 */
  .pc-rule {
    border: none; height: 0;
    border-top: 1.5px solid #96341C;
    width: 3.2rem; margin: 0 auto 2rem;
  }
  /* 카드2/3(입력 없는 카드)에서는 낙관 위치 — 본문 하단 마감 */
  .postcard.no-input .pc-rule { margin: 2rem auto 0; }
  .postcard.no-input .postcard-form { display: none; }

  /* ── 겹침 레이어 플레이스홀더 (부분 기울임용) ── */
  .pc-field { position: relative; display: flex; }
  .pc-field input { width: 100%; }
  .pc-ph {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    font-family: 'EB Garamond', serif;
    font-size: 1rem; letter-spacing: 0.12em;
    color: var(--ink-faint);
    pointer-events: none;
    transition: opacity 0.2s ease;
  }
  .pc-ph em { font-style: italic; }
  .pc-field.filled .pc-ph,
  .pc-field input:focus + .pc-ph { opacity: 0; }

  .postcard-text {
    font-family: 'Noto Serif KR', serif;
    font-size: clamp(1.1rem, 4.6cqw, 1.45rem);
    font-weight: 300; line-height: 1.7;
    color: var(--ink); margin-bottom: 2.5rem;
    min-height: 3.4em;
    display: flex; align-items: center; justify-content: center;
  }

  .postcard-form {
    display: flex; flex-direction: column; gap: 0.8rem;
    align-items: stretch;
  }
  .postcard-form input {
    font-family: 'EB Garamond', serif;
    font-size: 1rem; padding: 0.8rem 1rem;
    background: transparent;
    border: none; border-bottom: 1px solid var(--rule-strong);
    color: var(--ink); text-align: center;
    outline: none; transition: border-color 0.3s;
  }
  .postcard-form input:focus { border-color: var(--mark); }
  .postcard-form input::placeholder { color: var(--ink-faint); font-style: italic; }
  .postcard-submit {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem; letter-spacing: 0.25em; text-transform: uppercase;
    padding: 0.8rem; margin-top: 0.5rem;
    background: var(--ink); color: var(--paper);
    border: none; cursor: pointer;
    transition: background 0.3s;
  }
  .postcard-submit:hover { background: var(--mark); }

  .postcard-already {
    font-family: 'EB Garamond', serif; font-style: italic;
    font-size: 0.95rem; color: var(--ink-faint);
    display: none;
  }
  .postcard.subscribed .postcard-form { display: none; }
  .postcard.subscribed .postcard-already { display: block; }

  /* 전송 실패: 엽서 흔들림 */
  .postcard.shake {
    animation: postcard-shake 0.5s cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
  }
  @keyframes postcard-shake {
    10%, 90% { transform: translate(calc(-50% - 2px), -50%); }
    20%, 80% { transform: translate(calc(-50% + 4px), -50%); }
    30%, 50%, 70% { transform: translate(calc(-50% - 7px), -50%); }
    40%, 60% { transform: translate(calc(-50% + 7px), -50%); }
  }

  .spider-rig {
    position: fixed; top: 0; left: 50%;
    transform: translateX(-50%) translateY(-100%);
    transition: transform 0.95s cubic-bezier(0.45, 0, 0.55, 1);
    z-index: 3;
    pointer-events: none;
    display: flex; flex-direction: column; align-items: center;
  }
  .thread {
    width: 1px;
    height: 50vh;
    background: var(--ink-soft);
    opacity: 0.5;
  }
  .spider {
    margin-top: -40px;
  }
  .spider img {
    width: 540px; height: auto; display: block;
  }
  .carried-postcard {
    margin-top: -24px;
    display: flex;
    justify-content: center;
  }
  .carried-postcard .postcard {
    width: 540px !important;
    max-width: 80vw;
  }

  .spider-rig.descending {
    transform: translateX(-50%) translateY(-37vh);
  }
  .spider-rig.grabbing {
    transform: translateX(-50%) translateY(-39vh) scale(1.02);
    transition: transform 0.25s ease;
  }
  .spider-rig.ascending {
    transform: translateX(-50%) translateY(-110vh);
    transition: transform 1.1s cubic-bezier(0.5, 0, 0.75, 0);
  }

  .residue {
    position: fixed; top: 0; left: 50%;
    display: flex; gap: 4.5rem; align-items: flex-start;
    color: var(--ink-soft);
    opacity: 0; z-index: 2;
    pointer-events: none;
  }
  .residue.show { animation: residue-fall 3.4s ease-out forwards; }
  .residue .feather { width: 88px; }
  .residue .screw { width: 60px; }
  @keyframes residue-fall {
    0% { opacity: 0; transform: translate(-50%, -20%); }
    12% { opacity: 0.9; }
    65% { opacity: 0.9; }
    100% { opacity: 0; transform: translate(-50%, 60vh); }
  }

  @media (max-width: 900px) {
    .postcard { padding: 2.8rem 1.8rem 2.2rem; }
    .foot img { width: 90px; }
  }
  /* keyholder: 엽서 카드 전체가 가운데→양옆으로 갈라지며 사라짐 */
  .postcard.splitting {
    animation: card-part 1.1s cubic-bezier(0.45, 0, 0.3, 1) forwards;
    pointer-events: none;
  }
  @keyframes card-part {
    0% {
      opacity: 1;
      -webkit-mask-image: linear-gradient(to right, #000 49.5%, transparent 49.5%, transparent 50.5%, #000 50.5%);
      mask-image: linear-gradient(to right, #000 49.5%, transparent 49.5%, transparent 50.5%, #000 50.5%);
    }
    100% {
      opacity: 0.85;
      -webkit-mask-image: linear-gradient(to right, transparent 0%, transparent 50%, transparent 50%, transparent 100%);
      mask-image: linear-gradient(to right, transparent 0%, transparent 50%, transparent 50%, transparent 100%);
    }
  }

  /* 독립 로그인 박스 — stage 중앙, 평소 숨김 */
  .login-box {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: calc(100% - 3rem); max-width: 540px;
    background: var(--paper);
    border: none;
    padding: 2.6rem 2.4rem;
    text-align: center;
    box-shadow: 0 30px 70px rgba(28, 35, 64, 0.28);
    display: none;
    flex-direction: column; gap: 0.9rem;
    z-index: 2;
  }
  .login-box.show {
    display: flex;
    animation: login-fade 2s ease forwards;
  }
  @keyframes login-fade {
    0%   { opacity: 0; transform: translate(-50%, calc(-50% + 10px)); }
    100% { opacity: 1; transform: translate(-50%, -50%); }
  }
  .login-title {
    font-family: 'Noto Serif KR', serif;
    font-size: 1.3rem; font-weight: 400;
    color: var(--ink); margin-bottom: 0.6rem;
  }
  .login-box input {
    font-family: 'EB Garamond', serif;
    font-size: 1rem; padding: 0.8rem 1rem;
    background: transparent;
    border: none; border-bottom: 1px solid var(--rule-strong);
    color: var(--ink); text-align: center;
    outline: none; transition: border-color 0.3s;
  }
  .login-box input:focus { border-color: var(--mark); }
  .login-box input[readonly] { color: var(--ink-soft); cursor: default; }
  .login-msg {
    font-family: 'EB Garamond', serif; font-style: italic;
    font-size: 0.9rem; color: var(--ink-faint);
    margin-top: 0.8rem; min-height: 1.1em;
  }
  /* 갈라짐 반쪽 — 평소 숨김, 원래 엽서와 동일한 위치/크기 */
  .split-half {
    position: absolute; top: 50%; left: 50%;
    width: calc(100% - 3rem); max-width: 540px;
    height: var(--split-h, 300px);
    background: var(--paper);
    border: 1px solid var(--rule-strong);
    box-shadow: 0 30px 70px rgba(28, 35, 64, 0.28);
    display: none;
    z-index: 3;
  }
  .split-left {
    transform: translate(-50%, -50%);
    clip-path: inset(0 50% 0 0);
  }
  .split-right {
    transform: translate(-50%, -50%);
    clip-path: inset(0 0 0 50%);
  }
  .split-half.active { display: block; opacity: 1; filter: blur(0); }
  .split-half.part.split-left {
    transform: translate(calc(-50% - 160%), -50%);
    transition: transform 1.5s cubic-bezier(0.4, 0, 0.2, 1), opacity 1.5s ease, filter 1.5s ease;
    opacity: 0;
    filter: blur(6px);
  }
  .split-half.part.split-right {
    transform: translate(calc(-50% + 160%), -50%);
    transition: transform 1.5s cubic-bezier(0.4, 0, 0.2, 1), opacity 1.5s ease, filter 1.5s ease;
    opacity: 0;
    filter: blur(6px);
  }

  .login-close {
    position: absolute; top: 1rem; right: 1.2rem;
    background: none; border: none;
    font-family: 'EB Garamond', serif; font-size: 1.4rem;
    color: var(--ink-soft); cursor: pointer; line-height: 1;
    transition: color 0.3s, transform 0.3s;
  }
  .login-close:hover { color: var(--mark); transform: rotate(90deg); }
  /* 갈라짐 직선 — 가운데 세로, 위→아래로 그어짐 */
  .split-line {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 1px;
    height: var(--split-h, 300px);
    background: var(--ink);
    z-index: 4;
    display: none;
    clip-path: inset(0 0 100% 0);
  }
  .split-line.active { display: block; }
  .split-line.draw {
    clip-path: inset(0 0 0 0);
    transition: clip-path 0.6s ease-out;
  }
</style>

<script>
  import { supabase } from '../lib/supabaseClient.js';
  // 카드1: 첫 방문자(비로그인+판정 전). / 는 문장 강제 줄바꿈
  const SENTENCES_FIRST = [
    '자주 봅세. / 지금 들어온 문이 내일은 안 보일지도 모르니.',
    '흙탕물, 아수라장, 폭탄주, 엉망진창을 위하여!',
    '지나가던 길이오? / 다들 처음엔 그렇게 말하지.',
  ];
  // 카드2: initiate 판정 결과
  const SENTENCES_INITIATE = [
    '낯이 익소. / 또 살짝만 들렀다 가시게?',
    '거미는 잘 도착했소? / 편지 말이오.',
    '그쪽 자리는 아직 비워두었소.',
    '오늘도 구경만 하시게? / 뭐, 그것도 손님이지.',
  ];
  // 카드3: keyholder(로그인 세션 상태에서 물음표)
  const SENTENCES_KEYHOLDER = [
    '벽은 잘 넘나들고 계신가?',
    '방이 어질러진 건지, 너무 깔끔한 건지, 참 모르겠더군. / 아무튼 그대로 두었으니 걱정 마시오.',
    '눈치보지 말고, 어서 편하게 어울려 보시게.',
    '물어볼 게 있다? 방에 쪽지를 남겨두시오. / 내가 대장한테 갖다 드리리다.',
  ];
  // 직전 반복 금지: 세트별 마지막 인덱스 기억
  var _lastIdx = { first: -1, initiate: -1, keyholder: -1 };
  function pickSentence(setName, arr) {
    if (arr.length === 1) return arr[0];
    var i, guard = 0;
    do { i = Math.floor(Math.random() * arr.length); guard++; }
    while (i === _lastIdx[setName] && guard < 20);
    _lastIdx[setName] = i;
    return arr[i];
  }
  // '/'를 줄바꿈으로 — textContent 대신 안전하게 노드로 조립
  function setSentence(el, raw) {
    el.textContent = '';
    var parts = raw.split(' / ');
    for (var k = 0; k < parts.length; k++) {
      if (k > 0) el.appendChild(document.createElement('br'));
      el.appendChild(document.createTextNode(parts[k]));
    }
  }

  function sleep(ms) {
    return new Promise(function (resolve) { setTimeout(resolve, ms); });
  }

  function initPostcard() {
    const stage = document.getElementById('postcard-stage');
    const darken = document.getElementById('stage-darken');
    const postcard = document.getElementById('postcard');
    const textEl = document.getElementById('postcard-text');
    const form = document.getElementById('postcard-form');
    const emailInput = document.getElementById('postcard-email');
    const spiderRig = document.getElementById('spider-rig');
    const residue = document.getElementById('residue');
    const closeBtn = document.getElementById('postcard-close');
    const trigger = document.getElementById('question-trigger');
    const signupBox = document.getElementById('signup-box');

    if (!stage || !trigger) return;


    async function refreshSignupBox() {
      if (!signupBox) return;
      // 로그인(세션)된 keyholder → 가입버튼 숨김
      let loggedIn = false;
      try {
        const { data } = await supabase.auth.getSession();
        loggedIn = !!(data && data.session);
      } catch (e) {}
      // 로그인된 keyholder든 아니든, 페이지 로드 시엔 가입버튼 항상 숨김.
      // (가입버튼은 물음표→이메일 입력으로 initiate 판정된 순간에만 등장)
      signupBox.classList.remove('visible');
    }
    refreshSignupBox();

    // 거미가 엽서를 carried-postcard로 옮기므로, 원래 자리를 기억해 복구용으로 씀
    var postcardHome = postcard.parentNode;
    var postcardNextSibling = postcard.nextSibling;
    async function openPostcard() {
      // 거미 시퀀스가 엽서를 옮기고 인라인 스타일을 박아둠 → 원래 자리로 복구
      if (postcard.parentNode !== postcardHome) {
        if (postcardNextSibling && postcardNextSibling.parentNode === postcardHome) {
          postcardHome.insertBefore(postcard, postcardNextSibling);
        } else {
          postcardHome.appendChild(postcard);
        }
      }
      postcard.style.position = '';
      postcard.style.transform = '';
      postcard.style.transition = '';
      postcard.style.margin = '';
      postcard.style.left = '';
      postcard.style.top = '';
      postcard.style.display = '';
      postcard.style.visibility = '';
      postcard.classList.remove('grabbed');
      // 기본: 카드1(첫 방문자). 세션 확인되면 카드3으로 교체.
      postcard.classList.remove('no-input');
      setSentence(textEl, pickSentence('first', SENTENCES_FIRST));
      // 플레이스홀더 겹침 레이어 초기화
      var field = document.querySelector('.pc-field');
      if (field) field.classList.remove('filled');
      if (emailInput) emailInput.value = '';
      // 우선순위: 로그인 세션 → 카드3 / 가입버튼 이미 뜸(방금 initiate) → 카드2 / 그 외 → 카드1
      var loggedIn = false;
      try {
        const { data } = await supabase.auth.getSession();
        loggedIn = !!(data && data.session);
      } catch (e) {}
      if (loggedIn) {
        postcard.classList.add('no-input');
        setSentence(textEl, pickSentence('keyholder', SENTENCES_KEYHOLDER));
      } else if (signupBox && signupBox.classList.contains('visible')) {
        // 거미를 방금 거쳐 initiate가 된 사람 — 카드1(입력) 대신 카드2
        postcard.classList.add('no-input');
        setSentence(textEl, pickSentence('initiate', SENTENCES_INITIATE));
      }
      postcard.classList.remove('taken', 'splitting', 'show-login');
      postcard.style.display = '';
      postcard.style.visibility = '';
      var lb = document.getElementById('login-box');
      if (lb) lb.classList.remove('show');
      var sl = document.getElementById('split-left');
      var sr = document.getElementById('split-right');
      if (sl) sl.classList.remove('active', 'part');
      if (sr) sr.classList.remove('active', 'part');
      spiderRig.classList.remove('descending', 'ascending', 'grabbing');
      residue.classList.remove('show');
      postcard.classList.remove('subscribed');
      stage.classList.add('open');
    }

    function closePostcard() {
      stage.classList.remove('open');
      darken.classList.remove('darkened');
    }

    // 겹침 플레이스홀더: 값이 있으면 숨김 (IME 조합 중에도 안전 — value 기준)
    var pcField = document.querySelector('.pc-field');
    function syncPh() {
      if (!pcField) return;
      if (emailInput.value.length > 0) pcField.classList.add('filled');
      else pcField.classList.remove('filled');
    }
    if (emailInput) {
      emailInput.addEventListener('input', syncPh);
      emailInput.addEventListener('compositionupdate', syncPh);
      emailInput.addEventListener('blur', syncPh);
    }
    trigger.addEventListener('click', openPostcard);
    closeBtn.addEventListener('click', closePostcard);
    var loginClose = document.getElementById('login-close');
    if (loginClose) loginClose.addEventListener('click', closePostcard);

    // 로그인 처리 — '연다' 버튼
    var loginSubmit = document.getElementById('login-submit');
    if (loginSubmit) {
      loginSubmit.addEventListener('click', async function () {
        const emailEl = document.getElementById('login-email');
        const passEl = document.getElementById('login-pass');
        const msgEl = document.getElementById('login-msg');
        const email = emailEl ? emailEl.value : '';
        const password = passEl ? passEl.value : '';
        if (!password) { if (msgEl) msgEl.textContent = '봉인을 입력하십시오.'; return; }

        if (msgEl) msgEl.textContent = '여는 중...';
        loginSubmit.disabled = true;

        const { data, error } = await supabase.auth.signInWithPassword({
          email: email, password: password,
        });

        loginSubmit.disabled = false;

        if (error) {
          if (msgEl) msgEl.textContent = '열쇠가 맞지 않습니다.';
          if (passEl) { passEl.value = ''; passEl.focus(); }
          return;
        }

        // 로그인 성공 → Supabase 세션 저장됨. 새로고침하면 균열이 세션 보고 표시됨
        if (msgEl) msgEl.textContent = '문이 열립니다.';
        setTimeout(function () {
          window.scrollTo({ top: 0, behavior: 'smooth' });
          setTimeout(function () { location.reload(); }, 800);
        }, 1200);
      });
    }

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      const email = emailInput.value;
      if (!email) return;

      // 제출 중: 라벨만 '다가오는 중'으로 교체 (스피너 등 추가 요소 없음)
      const submitBtn = form.querySelector('.postcard-submit');
      const origBtnText = submitBtn ? submitBtn.textContent : '';
      if (submitBtn) { submitBtn.textContent = '다가오는 중'; submitBtn.disabled = true; }

      // 상태 조회
      let state = 'error';
      try {
        const res = await fetch('/.netlify/functions/check', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email }),
        });
        const data = await res.json();
        state = data.state;
      } catch (err) {
        state = 'error';
      }

      if (submitBtn) { submitBtn.textContent = origBtnText; submitBtn.disabled = false; }

      // invalid/error → 흔들기
      if (state === 'invalid' || state === 'error') {
        const original = emailInput.placeholder;
        postcard.classList.add('shake');
        emailInput.value = '';
        emailInput.placeholder = (state === 'invalid') ? '올바른 주소가 아닙니다' : '잠시 후 다시 시도해주세요';
        setTimeout(function () { postcard.classList.remove('shake'); }, 500);
        setTimeout(function () { emailInput.placeholder = original; }, 2600);
        return;
      }

      // initiate → 이미 다녀감 + 가입 버튼
      if (state === 'initiate') {
        // 카드2: 입력창 없는 소개문 엽서 + 낙관 위치 붉은줄. 가입버튼은 그대로 등장.
        postcard.classList.add('no-input');
        setSentence(textEl, pickSentence('initiate', SENTENCES_INITIATE));
        if (signupBox) signupBox.classList.add('visible');
        return;
      }

      // pending → 가입했으나 미확인. 확인 편지 자동 재발송
      if (state === 'pending') {
        textEl.textContent = '봉인은 정해졌으나, 아직 문이 확인되지 않았습니다. 편지를 다시 보냅니다…';
        form.style.display = 'none';
        try {
          await supabase.auth.resend({
            type: 'signup',
            email: email,
            options: { emailRedirectTo: 'https://nuh-muh.com/welcome' },
          });
          textEl.textContent = '확인의 편지를 다시 보냈습니다. 메일함과 스팸함을 살피십시오. 편지의 문을 열면, 이 자리가 스스로 당신을 맞이합니다.';
        } catch (e) {
          textEl.textContent = '편지를 다시 보내지 못했습니다. 잠시 후 다시 시도해 주십시오.';
        }
        // 폴링: 다른 곳에서 확인이 끝나면 이 화면이 감지해 새로고침
        var pPollEmail = email;
        var pPollCount = 0;
        var pPollMax = 75; // 4초 * 75 = 약 5분
        var pPollTimer = setInterval(async function () {
          pPollCount++;
          if (pPollCount > pPollMax) { clearInterval(pPollTimer); return; }
          try {
            const res = await fetch('/.netlify/functions/confirm', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ email: pPollEmail }),
            });
            const data = await res.json();
            if (data.status === 'ok') {
              clearInterval(pPollTimer);
              textEl.textContent = '문이 열립니다…';
              setTimeout(function () {
                window.scrollTo({ top: 0, behavior: 'smooth' });
                setTimeout(function () { location.reload(); }, 900);
              }, 1200);
            }
          } catch (e2) {}
        }, 4000);
        return;
      }
      // keyholder → 카드 갈라져 사라짐 → 빈 순간 → 로그인 박스 페이드인
      if (state === 'keyholder') {
        const loginEmail = document.getElementById('login-email');
        const loginBox = document.getElementById('login-box');
        if (loginEmail) loginEmail.value = email; // 이메일 자동완성

        const sLeft = document.getElementById('split-left');
        const sRight = document.getElementById('split-right');
        const sLine = document.getElementById('split-line');

        // 화면 어두워짐
        darken.classList.add('darkened');

        // 반쪽 높이를 원래 엽서에 맞춤
        const h = postcard.offsetHeight;
        if (sLeft) sLeft.style.setProperty('--split-h', h + 'px');
        if (sRight) sRight.style.setProperty('--split-h', h + 'px');
        if (sLine) sLine.style.setProperty('--split-h', h + 'px');

        // 1) 가운데 선이 위→아래로 그어짐
        if (sLine) {
          sLine.classList.add('active');
          setTimeout(function () { sLine.classList.add('draw'); }, 40);
        }

        // 2) 선 다 그어진 뒤 반쪽 나타나 양옆 미끄러짐
        setTimeout(function () {
          if (sLeft) sLeft.classList.add('active');
          if (sRight) sRight.classList.add('active');
          postcard.style.visibility = 'hidden';
          if (sLine) sLine.style.display = 'none';
          setTimeout(function () {
            if (sLeft) sLeft.classList.add('part');
            if (sRight) sRight.classList.add('part');
          }, 250);
        }, 700);

        // 미끄러짐 끝난 뒤 반쪽 치우고 로그인 박스 페이드인
        setTimeout(function () {
          if (sLeft) sLeft.classList.remove('active', 'part');
          if (sRight) sRight.classList.remove('active', 'part');
          if (loginBox) {
            loginBox.classList.add('show');
            const lp = document.getElementById('login-pass');
            if (lp) lp.focus();
          }
        }, 2700);
        return;
      }

      // new → 거미 시퀀스 (신규 가입)

      // DB에 실제 등록은 거미 시퀀스 중 subscribe 함수가 함 — 기존 흐름 유지
      try {
        await fetch('/.netlify/functions/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email }),
        });
      } catch (err) {}

      darken.classList.add('darkened');
      await sleep(600);
      spiderRig.classList.add('descending');
      await sleep(950);
      spiderRig.classList.add('grabbing');
      postcard.classList.add('grabbed');
      await sleep(400);
      const carried = document.getElementById('carried-postcard');
      postcard.style.position = 'static';
      postcard.style.transform = 'none';
      postcard.style.transition = 'none';
      postcard.style.margin = '0 auto';
      postcard.style.left = 'auto';
      postcard.style.top = 'auto';
      carried.appendChild(postcard);
      spiderRig.classList.remove('grabbing');
      spiderRig.classList.remove('descending');
      spiderRig.classList.add('ascending');
      await sleep(1150);
      darken.classList.remove('darkened');
      await sleep(600);
      closePostcard();
      // 방금 거미가 가져감 = 이 순간 initiate가 됨 → 가입버튼 등장
      // (localStorage 저장 안 함 — 새로고침하면 사라지는 게 맞음)
      if (signupBox) signupBox.classList.add('visible');
    });
  }
  // 모듈 스크립트는 이미 DOM 로드 후 실행됨 → 바로/대기 양쪽 대응
  if (document.readyState !== 'loading') initPostcard();
  else document.addEventListener('DOMContentLoaded', initPostcard);
  document.addEventListener('astro:page-load', initPostcard);
</script>
