---
import type { Work } from '../data/works';
interface Props { work: Work; revealClass?: string; }
const { work, revealClass = '' } = Astro.props;
---
<a href={`/work/${work.id}`} class={`card card-spotlight color-${work.color} reveal ${revealClass}`}>
  <div>
    <div class="card-top">
      <span>{work.number}{work.kicker ? ` · ${work.kicker}` : ''}</span>
      {work.status && <span class="status">{work.status}</span>}
    </div>
    <h2 class="card-title">{work.title}</h2>
    <p class="card-tag">{work.tag}</p>
    {work.excerpt && <p class="card-excerpt">{work.excerpt}</p>}
  </div>
  <div class="card-foot">
    <span>{work.articleCount}편</span>
    <span>읽기 <span class="arrow">→</span></span>
  </div>
</a>

<style>
  .card {
    background: var(--paper); border: 1px solid var(--rule);
    padding: 3rem 2.8rem; position: relative;
    display: flex; flex-direction: column; justify-content: space-between;
    cursor: pointer; text-decoration: none; color: inherit; overflow: hidden;
    transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.3s, filter 0.4s;
    grid-column: span 8; grid-row: span 2;
  }
  .card::after {
    content: ''; position: absolute; left: 0; top: 0;
    width: 3px; height: 0; background: var(--mark);
    transition: height 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .card:hover { transform: translateY(-5px); border-color: var(--rule-strong); filter: brightness(1.02); }
  .card:hover::after { height: 100%; }
  .card-top {
    display: flex; justify-content: space-between; align-items: flex-start;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--ink-faint); margin-bottom: 2.2rem;
  }
  .card-top .status { color: var(--mark); }
  .card-title {
    font-family: 'Noto Serif KR', serif; font-weight: 600;
    font-size: clamp(2.6rem, 4.5vw, 3.8rem);
    line-height: 1.05; letter-spacing: -0.01em; margin-bottom: 1.2rem;
    transition: letter-spacing 0.4s;
  }
  .card:hover .card-title { letter-spacing: 0.005em; }
  .card-tag {
    font-family: 'EB Garamond', serif; font-style: italic;
    font-size: 1.18rem; color: var(--ink-soft); line-height: 1.4; margin-bottom: 1.8rem;
  }
  .card-excerpt {
    font-family: 'Noto Serif KR', serif; font-size: 1.02rem; line-height: 1.8;
    font-weight: 300; color: var(--ink-soft); max-width: 520px; margin-bottom: auto;
  }
  .card-foot {
    display: flex; justify-content: space-between; align-items: center;
    margin-top: 1.8rem; font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-soft);
  }
  .card-foot .arrow { display: inline-block; transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), color 0.3s; }
  .card:hover .arrow { transform: translateX(6px); color: var(--mark); }
  .color-warm { background: var(--paper-warm); }
  .color-deep { background: var(--paper-deep); }
  .color-cold { background: var(--paper-cold); }
  .color-rust { background: var(--paper-rust); }
  .color-mossy { background: var(--paper-mossy); }
  .color-ash { background: var(--paper-ash); }
  @media (max-width: 900px) {
    .card { grid-column: span 1; grid-row: auto; padding: 2.2rem 1.8rem; min-height: 180px; }
  }
</style>
